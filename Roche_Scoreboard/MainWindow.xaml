<Window x:Class="Roche_Scoreboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Roche_Scoreboard.Views"
        Title="Roche Scoreboard v2.8.0"
        Height="1050"
        Width="1550"
        MinWidth="420"
        MinHeight="320"
        WindowStartupLocation="Manual"
        Background="#0D1117">

    <Window.Resources>
        <!-- ═══════════════════════════════════ -->
        <!-- COLOUR SYSTEM — broadcast console   -->
        <!-- ═══════════════════════════════════ -->
        <SolidColorBrush x:Key="ShellBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="RegionBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="RegionAltBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="RegionEdgeBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="SectionEdgeBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMidBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#484F58"/>
        <SolidColorBrush x:Key="HomeAccentBrush" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AwayAccentBrush" Color="#F85149"/>
        <SolidColorBrush x:Key="LiveBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#D29922"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#58A6FF"/>

        <!-- ── Section heading — uppercase, tracked ── -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── Primary command button — scoring, with tactile depress and hover lift ── -->
        <Style x:Key="PrimaryCommandButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5" Opacity="1">
                            <Border.RenderTransform><ScaleTransform x:Name="Sc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover: subtle lift + brightness -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!-- Press: compress + dim for tactile feedback -->
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <!-- Click: snap-compress rebound -->
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0.65" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tool button — compact, hover glow, tactile press ── -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5" Opacity="1">
                            <Border.RenderTransform><ScaleTransform x:Name="TbSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover: surface highlight + micro lift -->
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <!-- Click: snap-compress rebound -->
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0.7" To="1" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab navigation — broadcast channel selector with glow ── -->
        <Style x:Key="PanelTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="#50606E"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Bd" Background="#0C1018" Padding="20,9"
                                    BorderThickness="1,1,1,0" BorderBrush="#161E2A">
                                <ContentPresenter x:Name="Cp" ContentSource="Header"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <!-- Active accent bar -->
                            <Border x:Name="AccBar" VerticalAlignment="Bottom" Height="2"
                                    Opacity="0" Margin="8,0,8,-1">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#0058A6FF" Offset="0"/>
                                        <GradientStop Color="#FF58A6FF" Offset="0.5"/>
                                        <GradientStop Color="#0058A6FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#111822"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#1C2838"/>
                                <Setter TargetName="AccBar" Property="Opacity" Value="1"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F1620"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="#B0C0D0"/>
                            </Trigger>
                            <!-- Selected + hover keeps white -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="White"/>
                                <Setter TargetName="Bd" Property="Background" Value="#131C28"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Layout/animation radio selector with hover animation ── -->
        <Style x:Key="LayoutRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextMidBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#1C2128" BorderBrush="#30363D" BorderThickness="1" Padding="12,7"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="RbSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#21262D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RbSc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RbSc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RbSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="RbSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </Window.Resources>

    <Grid Background="{StaticResource ShellBrush}">
        <!-- ══════════════════════════════════════════ -->
        <!-- MAIN CONTENT — live match command surface  -->
        <!-- ══════════════════════════════════════════ -->
        <Grid x:Name="MainContent" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══ PERSISTENT MATCH STRIP — cinematic broadcast header ═══ -->
            <Border x:Name="MatchStripBorder" Grid.Row="0" BorderBrush="#1A2030" BorderThickness="0,0,0,1" Visibility="Collapsed">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0C1018" Offset="0"/>
                        <GradientStop Color="#111822" Offset="0.3"/>
                        <GradientStop Color="#111822" Offset="0.7"/>
                        <GradientStop Color="#0C1018" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Subtle ambient glow behind centre clock -->
                    <Border IsHitTestVisible="False" Opacity="0.08" HorizontalAlignment="Center" Width="400">
                        <Border.Background>
                            <RadialGradientBrush Center="0.5,0.6" RadiusX="0.6" RadiusY="1.2">
                                <GradientStop Color="#58A6FF" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    <!-- Bottom accent line -->
                    <Border VerticalAlignment="Bottom" Height="1" IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#0058A6FF" Offset="0"/>
                                <GradientStop Color="#4058A6FF" Offset="0.35"/>
                                <GradientStop Color="#6058A6FF" Offset="0.5"/>
                                <GradientStop Color="#4058A6FF" Offset="0.65"/>
                                <GradientStop Color="#0058A6FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="20,8,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left: Status badge -->
                        <Border x:Name="StatusBadge" Grid.Column="0" Background="#0A1A10" Padding="10,4" VerticalAlignment="Center">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A4A2A" Offset="0"/>
                                    <GradientStop Color="#244A34" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="StatusDot" Width="7" Height="7" Fill="#3FB950" Margin="0,0,6,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect Color="#3FB950" BlurRadius="8" ShadowDepth="0" Opacity="0.6"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="StatusText" Text="READY" Foreground="#3FB950" FontSize="10" FontWeight="Black"/>
                            </StackPanel>
                        </Border>

                        <!-- Centre: Clock + last event -->
                        <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderQuarterClock" Text="Q1  00:00" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="#58A6FF" BlurRadius="16" ShadowDepth="0" Opacity="0.2"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="LastEventText" Text="" Foreground="#485868" FontSize="9" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>

                        <!-- Right: Score readout -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderHomeAbbr" Text="HOM" Foreground="{StaticResource HomeAccentBrush}" FontSize="12" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="HeaderScore" Text="0 – 0" Foreground="White" FontSize="26" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect Color="White" BlurRadius="12" ShadowDepth="0" Opacity="0.15"/>
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock x:Name="HeaderAwayAbbr" Text="AWA" Foreground="{StaticResource AwayAccentBrush}" FontSize="12" FontWeight="Black" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            <Border Background="#0A0E16" BorderBrush="#1A2540" BorderThickness="1" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="HeaderMarginText" Text="" Foreground="{StaticResource TextMidBrush}" FontSize="9" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══ TAB BAR — broadcast channel selector ═══ -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Grid.RowSpan="2" Background="#090D14" BorderThickness="0" Padding="0" TabStripPlacement="Top" SelectionChanged="MainTabControl_SelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource PanelTab}"/>
                </TabControl.Resources>
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" HorizontalAlignment="Stretch"/>
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <!-- ══════════════════════════════════════════ -->
                <!-- TAB 1: SCORING &amp; CLOCK — the heart    -->
                <!-- ══════════════════════════════════════════ -->
                <TabItem Header="SCORING &amp; CLOCK">
                    <Border Background="{StaticResource RegionBrush}" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0" Padding="12,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="290" MinWidth="260"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Scoring controls — command deck -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Scoring header with match result -->
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="SCORING" Style="{StaticResource SectionHead}" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" BorderBrush="#30363D" BorderThickness="1" Background="#0D1117" Padding="12,4">
                                        <TextBlock x:Name="MatchResultText" Text="" Foreground="{StaticResource TextMidBrush}" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Scoring panels — asymmetric team-coloured zones -->
                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- HOME scoring zone — thick top accent -->
                                    <Border x:Name="HomeScoringBorder" Grid.Column="0" BorderBrush="#33579A" BorderThickness="1,3,1,1" Background="#0A1428" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="HomeScoringLabel" Text="HOME" Foreground="#7EB4FF" FontSize="10" FontWeight="Black"/>
                                            <TextBlock Grid.Row="1" x:Name="HomeScoreDisplay" Text="0.0.0" Foreground="White" FontSize="52" FontWeight="Black" FontFamily="Bahnschrift" Margin="0,4,0,0"/>

                                            <Grid Grid.Row="3">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Button x:Name="HomeGoalButton" Grid.Row="0" Click="HomeGoal_Click" Style="{StaticResource PrimaryCommandButton}" ToolTip="Goal (+6 points) — Ctrl+G" BorderBrush="#4D7DE7" Background="#2F63D1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="+6 GOAL" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Ctrl+G" FontSize="10" Foreground="#FFFFFF80" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="HomeBehindButton" Grid.Row="2" Click="HomeBehind_Click" Style="{StaticResource PrimaryCommandButton}" FontSize="16" ToolTip="Behind (+1 point) — Ctrl+B" BorderBrush="#3A4E66" Background="#1A2636">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="+1 BEHIND" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Ctrl+B" FontSize="10" Foreground="#FFFFFF80" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <!-- AWAY scoring zone — thick top accent -->
                                    <Border x:Name="AwayScoringBorder" Grid.Column="2" BorderBrush="#8A3A3A" BorderThickness="1,3,1,1" Background="#1C0A0A" Padding="12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock x:Name="AwayScoringLabel" Text="AWAY" Foreground="#FF9A9A" FontSize="10" FontWeight="Black"/>
                                            <TextBlock Grid.Row="1" x:Name="AwayScoreDisplay" Text="0.0.0" Foreground="White" FontSize="52" FontWeight="Black" FontFamily="Bahnschrift" Margin="0,4,0,0"/>

                                            <Grid Grid.Row="3">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>
                                                <Button x:Name="AwayGoalButton" Grid.Row="0" Click="AwayGoal_Click" Style="{StaticResource PrimaryCommandButton}" ToolTip="Goal (+6 points) — Alt+G" BorderBrush="#C56F6F" Background="#A63B3B">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="+6 GOAL" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Alt+G" FontSize="10" Foreground="#FFFFFF80" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button x:Name="AwayBehindButton" Grid.Row="2" Click="AwayBehind_Click" Style="{StaticResource PrimaryCommandButton}" FontSize="16" ToolTip="Behind (+1 point) — Alt+B" BorderBrush="#5A3A3A" Background="#2A1A1A">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="+1 BEHIND" VerticalAlignment="Center"/>
                                                        <TextBlock Text=" Alt+B" FontSize="10" Foreground="#FFFFFF80" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Warning banner — amber accent -->
                                <Border x:Name="StartSwitchWarning" Grid.Row="3" Background="#1E1A00" BorderBrush="#D29922" BorderThickness="1,2,1,1" Padding="10,6" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="⚡" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Pressing Start will switch to the live scoreboard" Foreground="#D29922" FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <!-- Clock controls — amber accent zone, grouped tight -->
                                <Grid Grid.Row="5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" x:Name="StartPauseButton" Content="▶ Start" Height="60" FontSize="22" FontWeight="Black" Click="StartPause_Click"
                                            Background="#0D3018" BorderBrush="#1A6040" BorderThickness="1.5" Style="{StaticResource PrimaryCommandButton}"
                                            ToolTip="Start or pause the game clock — Space"/>
                                    <Button Grid.Column="2" x:Name="EndQtrButton" Content="End Qtr" Height="60" FontSize="12" FontWeight="Bold" Click="EndQuarter_Click" Style="{StaticResource ToolBtn}" ToolTip="End the current quarter — Ctrl+E"
                                            Background="#21262D" BorderBrush="#D29922"/>
                                    <Button Grid.Column="2" x:Name="ContinueQtrButton" Content="↩ Resume Q" Height="60" FontSize="11" FontWeight="Bold" Click="ContinueQuarter_Click"
                                            Style="{StaticResource ToolBtn}" ToolTip="Resume the previous quarter from where it left off — does NOT start the next quarter"
                                            Background="#1A2A14" BorderBrush="#3A6030" Foreground="#7EE068" Visibility="Collapsed"/>
                                    <Button Grid.Column="4" x:Name="UndoButton" Content="UNDO" Height="60" FontSize="12" FontWeight="Bold" Click="Undo_Click" Style="{StaticResource ToolBtn}" ToolTip="Undo the last score — Ctrl+Z"
                                            Background="#2A1416" BorderBrush="#6B3A3E"/>
                                </Grid>

                                <!-- Reset Match — danger zone, prominent but not dominant -->
                                <Button Grid.Row="7" Content="⟲  RESET MATCH" Height="42" FontSize="13" FontWeight="Black" Click="ResetMatch_Click"
                                        Style="{StaticResource ToolBtn}" ToolTip="Reset the entire match and return to setup"
                                        Background="#2A1416" BorderBrush="#6B3A3E" Foreground="#FF6B6B"/>
                            </Grid>

                            <!-- RIGHT: Event log — live feed style -->
                            <Border Grid.Column="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1" CornerRadius="6" Padding="0" ClipToBounds="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header bar -->
                                    <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="12,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#818CF8" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <TextBlock Text="MATCH LOG" FontSize="10" FontWeight="Black" Foreground="#818CF8" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="MatchLogCountBadge" Text="" FontSize="9" FontWeight="Bold" Foreground="#484F58" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Scrollable event list -->
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="6,4">
                                        <StackPanel x:Name="EventList"/>
                                    </ScrollViewer>

                                    <!-- Empty state hint -->
                                    <TextBlock x:Name="MatchLogEmptyHint" Grid.Row="1" Text="Score events will appear here"
                                               Foreground="#30363D" FontSize="11" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ══════════════════════════════════════════ -->
                <!-- TAB 2: DISPLAY & MESSAGES — cinematic      -->
                <!-- ══════════════════════════════════════════ -->
                <TabItem Header="DISPLAY &amp; MESSAGES">
                    <Border Background="#0A0E18" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <!-- Ambient background glow -->
                            <Border Opacity="0.06" IsHitTestVisible="False">
                                <Border.Background>
                                    <RadialGradientBrush Center="0.3,0.2" RadiusX="0.7" RadiusY="0.7">
                                        <GradientStop Color="#58A6FF" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            <!-- Vignette -->
                            <Border IsHitTestVisible="False">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#00000000" Offset="0.3"/>
                                        <GradientStop Color="#40000000" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <Grid Margin="20,16,20,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- ══════ LEFT: Presentation + Overlays ══════ -->
                                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>
                                        <!-- ── PRESENTATION MODE ── -->
                                        <StackPanel HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <TextBlock Text="PRESENTATION MODE" FontSize="14" FontWeight="Black" Foreground="#58A6FF" Margin="0,0,0,2">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#58A6FF" Opacity="0.3"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock Text="Select the active display for the scoreboard window" FontSize="9" FontWeight="SemiBold" Foreground="#3A5A80"/>
                                        </StackPanel>

                                        <TextBlock x:Name="CurrentDisplayText" Text="Live Scorebug" Foreground="#58A6FF" FontSize="10" FontWeight="Black" Margin="2,0,0,10"/>

                                        <!-- Presentation card grid — 4 columns -->
                                        <UniformGrid Columns="4" Margin="0,0,0,6">
                                            <!-- Scorebug -->
                                            <Border x:Name="PresCardScorebug" Cursor="Hand" Background="#0A1628" BorderBrush="#58A6FF" BorderThickness="2" Margin="3" MouseLeftButtonUp="PresCardScorebug_Click">
                                                <Grid MinHeight="90">
                                                    <Border x:Name="PresGlowScorebug" Opacity="0.12" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                <GradientStop Color="#58A6FF" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="📊" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="SCOREBUG" FontSize="11" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Live overlay" FontSize="8" Foreground="#5080AA" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckScorebug" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Summary -->
                                            <Border x:Name="PresCardSummary" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardSummary_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="SUMMARY" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Quarter break" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckSummary" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2" Visibility="Collapsed">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Worm -->
                                            <Border x:Name="PresCardWorm" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardWorm_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="📈" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="WORM" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Score graph" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckWorm" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2" Visibility="Collapsed">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Stats -->
                                            <Border x:Name="PresCardStats" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardStats_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="📉" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="STATS" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Full stats" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckStats" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2" Visibility="Collapsed">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Weather -->
                                            <Border x:Name="PresCardWeather" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardWeather_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="☁" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="WEATHER" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Forecast" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckWeather" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2" Visibility="Collapsed">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Video -->
                                            <Border x:Name="PresCardVideo" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardVideo_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock Text="🎬" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock Text="VIDEO" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <TextBlock Text="Custom file" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                    <Border x:Name="PresCheckVideo" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="5,2" Visibility="Collapsed">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <!-- Window Toggle -->
                                            <Border x:Name="PresCardWindow" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="3" MouseLeftButtonUp="PresCardWindow_Click">
                                                <Grid MinHeight="90">
                                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                        <TextBlock x:Name="WindowToggleIcon" Text="🖥" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                        <TextBlock x:Name="WindowToggleTitle" Text="WINDOW" FontSize="11" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        <!-- Toggle pill indicator -->
                                                        <Grid HorizontalAlignment="Center" Margin="0,5,0,0" Width="40" Height="20" Cursor="Hand">
                                                            <Border x:Name="WindowToggleTrack" CornerRadius="10" Background="#21262D" BorderBrush="#30363D" BorderThickness="1"/>
                                                            <Border x:Name="WindowToggleThumb" Width="16" Height="16" CornerRadius="8" Background="#6A6A80" HorizontalAlignment="Left" Margin="2,0,0,0" VerticalAlignment="Center">
                                                                <Border.RenderTransform>
                                                                    <TranslateTransform x:Name="WindowToggleThumbTranslate" X="0"/>
                                                                </Border.RenderTransform>
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock x:Name="WindowToggleLabel" Text="Open" FontSize="8" Foreground="#4A4A60" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </UniformGrid>

                                        <!-- Video picker panel -->
                                        <Border x:Name="VideoPickerPrompt" Visibility="Collapsed" Background="#0A0E18" BorderBrush="#2A3A52" BorderThickness="1" Padding="14" Margin="3,0,3,10">
                                            <Grid>
                                                <Border Opacity="0.05" IsHitTestVisible="False">
                                                    <Border.Background>
                                                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                            <GradientStop Color="#58A6FF" Offset="0"/>
                                                            <GradientStop Color="#00000000" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel>
                                                    <TextBlock Text="SELECT VIDEO FILE" Foreground="#58A6FF" FontSize="9" FontWeight="Black" Margin="0,0,0,8"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock x:Name="VideoFilePathText" Text="No file selected" Foreground="#5080AA" FontSize="11" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <Button Grid.Column="1" Content="Browse" Width="70" Click="BrowseVideo_Click" Style="{StaticResource ToolBtn}" Margin="8,0,0,0" BorderBrush="#2A3A52"/>
                                                    </Grid>
                                                    <Button x:Name="ApplyVideoButton" Content="Apply" Height="30" FontSize="11" FontWeight="Bold" Click="ApplyVideo_Click" Style="{StaticResource ToolBtn}" Margin="0,10,0,0" IsEnabled="False" BorderBrush="#2A3A52"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- ── OVERLAYS ── -->
                                        <Border Height="1" Margin="0,6,0,14">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#0058A6FF" Offset="0"/>
                                                    <GradientStop Color="#3058A6FF" Offset="0.5"/>
                                                    <GradientStop Color="#0058A6FF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                            <TextBlock Text="OVERLAYS" FontSize="14" FontWeight="Black" Foreground="#3FB950" Margin="0,0,0,2">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#3FB950" Opacity="0.3"/>
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <TextBlock Text="Trigger one-shot overlays on the live scorebug" FontSize="9" FontWeight="SemiBold" Foreground="#2A6030"/>
                                        </StackPanel>

                                        <!-- ── GAME ANALYSIS ── -->
                                        <TextBlock Text="GAME ANALYSIS" FontSize="9" FontWeight="Black" Foreground="#5AAA68" Margin="3,0,0,6"/>
                                        <UniformGrid Columns="4" Margin="0,0,0,10">
                                            <Border Cursor="Hand" Background="#081A0E" BorderBrush="#1A4028" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayStatsBar_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="📊" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="STATS BAR" FontSize="9" FontWeight="Black" Foreground="#5AAA68" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#081A0E" BorderBrush="#1A4028" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayWinProb_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🎯" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="WIN PROB" FontSize="9" FontWeight="Black" Foreground="#5AAA68" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#081A0E" BorderBrush="#1A4028" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayLeadChanges_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="↕" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="LEAD CHANGES" FontSize="8" FontWeight="Black" Foreground="#5AAA68" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#081A0E" BorderBrush="#1A4028" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayQtrScores_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🏁" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="QTR SCORES" FontSize="8" FontWeight="Black" Foreground="#5AAA68" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#081A0E" BorderBrush="#1A4028" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayRecentScores_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="📋" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="Recent Scores" FontSize="8" FontWeight="Black" Foreground="#5AAA68" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <!-- ── SCORING EVENTS ── -->
                                        <TextBlock Text="SCORING EVENTS" FontSize="9" FontWeight="Black" Foreground="#D29922" Margin="3,0,0,6"/>
                                        <UniformGrid Columns="4" Margin="0,0,0,10">
                                            <Border Cursor="Hand" Background="#14100A" BorderBrush="#3A2A10" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayScoringRun_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🔥" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="SCORING RUN" FontSize="9" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#14100A" BorderBrush="#3A2A10" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayScoreless_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="⏱" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="LAST SCORE" FontSize="9" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#0A1428" BorderBrush="#1A2A44" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayHomeDrought_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🏠" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="HOME DROUGHT" FontSize="8" FontWeight="Black" Foreground="#7EB4FF" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#1A0A0A" BorderBrush="#3A1A1A" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayAwayDrought_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="✈" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="AWAY DROUGHT" FontSize="8" FontWeight="Black" Foreground="#FF9A9A" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <!-- ── DISPLAY ── -->
                                        <TextBlock Text="DISPLAY" FontSize="9" FontWeight="Black" Foreground="#58A6FF" Margin="3,0,0,6"/>
                                        <UniformGrid Columns="4" Margin="0,0,0,10">
                                            <Border Cursor="Hand" Background="#1A1408" BorderBrush="#3A3018" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayWarning_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="5 MIN WARN" FontSize="9" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <!-- ── WEATHER &amp; CONDITIONS ── -->
                                        <TextBlock Text="WEATHER &amp; CONDITIONS" FontSize="9" FontWeight="Black" Foreground="#6EAAD4" Margin="3,0,0,6"/>
                                        <UniformGrid Columns="3" Margin="0,0,0,4">
                                            <Border Cursor="Hand" Background="#06101C" BorderBrush="#14284A" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayWeatherForecast_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="☀" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="FORECAST" FontSize="9" FontWeight="Black" Foreground="#6EAAD4" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#06101C" BorderBrush="#14284A" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayWeatherStats_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🌡" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="WEATHER" FontSize="9" FontWeight="Black" Foreground="#6EAAD4" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <Border Cursor="Hand" Background="#06101C" BorderBrush="#14284A" BorderThickness="1" Margin="3" MouseLeftButtonUp="OverlayRainForecast_Click">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="4,10">
                                                    <TextBlock Text="🌧" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,3"/>
                                                    <TextBlock Text="RAIN" FontSize="9" FontWeight="Black" Foreground="#6EAAD4" HorizontalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </ScrollViewer>

                                <!-- ══════ RIGHT: Messages ══════ -->
                                <Border Grid.Column="2" Background="#0A0E18" BorderBrush="#1A2A40" BorderThickness="1" ClipToBounds="True">
                                    <Grid>
                                        <Border Opacity="0.06" IsHitTestVisible="False">
                                            <Border.Background>
                                                <RadialGradientBrush Center="0.5,0.15" RadiusX="0.6" RadiusY="0.5">
                                                    <GradientStop Color="#3FB950" Offset="0"/>
                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <Grid Margin="16,14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Section header -->
                                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                <TextBlock Text="📺" FontSize="28" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                <TextBlock Text="TICKER MESSAGES" FontSize="16" FontWeight="Black" Foreground="#3FB950" HorizontalAlignment="Center">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="15" ShadowDepth="0" Color="#3FB950" Opacity="0.4"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Scroll across the bottom bar during the game" FontSize="9" FontWeight="SemiBold" Foreground="#2A6030" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Row="1" Height="1" Margin="0,0,0,10">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#003FB950" Offset="0"/>
                                                        <GradientStop Color="#303FB950" Offset="0.5"/>
                                                        <GradientStop Color="#003FB950" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <!-- Message list -->
                                            <Border Grid.Row="2" Background="#060A10" BorderBrush="#1A2A3A" BorderThickness="1" Padding="6">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsControl x:Name="MessageList">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Margin="0,0,0,6" Padding="8,6" Background="#0A1018" BorderBrush="#1E3050" BorderThickness="1" CornerRadius="3">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto"/>
                                                                            <RowDefinition Height="Auto"/>
                                                                        </Grid.RowDefinitions>

                                                                        <!-- Preview row -->
                                                                        <Border Grid.Row="0" Grid.ColumnSpan="4" CornerRadius="2" Padding="6,3" Margin="0,0,0,4"
                                                                                Background="{Binding HighlightBrush}">
                                                                            <TextBlock Text="{Binding Text}" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                                                       Foreground="{Binding TextBrush}"/>
                                                                        </Border>

                                                                        <!-- Edit row: text + colour pickers + remove -->
                                                                        <TextBox Grid.Row="1" Grid.Column="0"
                                                                                 Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                                                 FontSize="12" Background="#060A10" Foreground="#E6EDF3"
                                                                                 BorderBrush="#1E3050" CaretBrush="White"
                                                                                 Padding="6,4" VerticalContentAlignment="Center"
                                                                                 Margin="0,0,6,0"
                                                                                 TextChanged="MessageItem_TextChanged"/>

                                                                        <!-- Text colour picker -->
                                                                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Vertical" Margin="0,0,4,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="TEXT" FontSize="8" FontWeight="Bold" Foreground="#6E7B8A" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                                                            <Button Width="34" Height="22" Padding="0" BorderBrush="#1E3050" BorderThickness="1"
                                                                                    Click="PickItemTextColor_Click" Tag="{Binding}"
                                                                                    ToolTip="Click to choose text colour"
                                                                                    Background="{Binding TextBrush}"/>
                                                                        </StackPanel>

                                                                        <!-- Highlight colour picker -->
                                                                        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                                                                            <TextBlock Text="HIGHLIGHT" FontSize="8" FontWeight="Bold" Foreground="#6E7B8A" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                                                            <Button Width="50" Height="22" Padding="0" BorderBrush="#1E3050" BorderThickness="1"
                                                                                    Click="PickItemHighlightColor_Click" Tag="{Binding}"
                                                                                    ToolTip="Click to choose highlight colour. Right-click to clear."
                                                                                    MouseRightButtonUp="ClearItemHighlightColor_Click"
                                                                                    Background="{Binding HighlightBrush}"/>
                                                                        </StackPanel>

                                                                        <Button Grid.Row="1" Grid.Column="3"
                                                                                Content="✕" Width="30" Height="40" FontSize="12" FontWeight="Black"
                                                                                Click="RemoveMessageItem_Click" Tag="{Binding}"
                                                                                Style="{StaticResource ToolBtn}" BorderBrush="#3A1A1A"
                                                                                VerticalAlignment="Bottom"
                                                                                ToolTip="Remove this message"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Border>

                                            <!-- Add controls (text + colour pickers + add) -->
                                            <Grid Grid.Row="3" Margin="0,10,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox x:Name="NewMessageBox" FontSize="12" Background="#0A1018" Foreground="#E6EDF3" BorderBrush="#1E3050" CaretBrush="White" Padding="10,7" VerticalContentAlignment="Center" Margin="0,0,6,0" KeyDown="NewMessageBox_KeyDown"/>

                                                <!-- New text colour picker -->
                                                <StackPanel Grid.Column="1" Orientation="Vertical" Margin="0,0,4,0" VerticalAlignment="Center">
                                                    <TextBlock Text="TEXT" FontSize="8" FontWeight="Bold" Foreground="#6E7B8A" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                                    <Button x:Name="NewMessageTextColorBtn" Width="40" Height="22" Padding="0" BorderBrush="#1E3050" BorderThickness="1"
                                                            Background="White"
                                                            Click="PickNewTextColor_Click"
                                                            ToolTip="Click to choose text colour for the new message"/>
                                                </StackPanel>

                                                <!-- New highlight colour picker -->
                                                <StackPanel Grid.Column="2" Orientation="Vertical" Margin="0,0,6,0" VerticalAlignment="Center">
                                                    <TextBlock Text="HIGHLIGHT" FontSize="8" FontWeight="Bold" Foreground="#6E7B8A" HorizontalAlignment="Center" Margin="0,0,0,1"/>
                                                    <Button x:Name="NewMessageHighlightColorBtn" Width="56" Height="22" Padding="0" BorderBrush="#1E3050" BorderThickness="1"
                                                            Background="Transparent"
                                                            Click="PickNewHighlightColor_Click"
                                                            MouseRightButtonUp="ClearNewHighlightColor_Click"
                                                            ToolTip="Click to choose highlight colour. Right-click to clear (no highlight)."/>
                                                </StackPanel>

                                                <Button Grid.Column="3" Content="+" Width="34" Height="40" FontSize="14" FontWeight="Black" Click="AddMessage_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A24" VerticalAlignment="Bottom"/>
                                            </Grid>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ══════════════════════════════════════════ -->
                <!-- TAB 3: SETTINGS — cinematic full-screen     -->
                <!-- ══════════════════════════════════════════ -->
                <TabItem Header="SETTINGS">
                    <Border Background="#0A0E18" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0">
                        <Grid>
                            <!-- Ambient glow -->
                            <Border Opacity="0.05" IsHitTestVisible="False">
                                <Border.Background>
                                    <RadialGradientBrush Center="0.7,0.2" RadiusX="0.6" RadiusY="0.6">
                                        <GradientStop Color="#3FB950" Offset="0"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            <Border IsHitTestVisible="False">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#00000000" Offset="0.3"/>
                                        <GradientStop Color="#30000000" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Hidden backing radio buttons -->
                            <RadioButton x:Name="ClockModeCountUp" IsChecked="True" GroupName="ClockMode" Checked="ClockMode_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="ClockModeCountdown" GroupName="ClockMode" Checked="ClockMode_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="LayoutClassicRadio" GroupName="LayoutChoice" IsChecked="True" Checked="LayoutRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="LayoutExpandedRadio" GroupName="LayoutChoice" Checked="LayoutRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="LayoutRetroRadio" GroupName="LayoutChoice" Checked="LayoutRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="LayoutNoLogosRadio" GroupName="LayoutChoice" Checked="LayoutRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimBroadcastRadio" GroupName="AnimChoice" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimElectricRadio" GroupName="AnimChoice" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimCinematicRadio" GroupName="AnimChoice" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimCleanRadio" GroupName="AnimChoice" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimClassicRadio" GroupName="AnimChoice" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <RadioButton x:Name="AnimCustomVideoRadio" GroupName="AnimChoice" IsChecked="True" Checked="AnimationRadio_Changed" Visibility="Collapsed"/>
                            <!-- Hidden backing controls -->
                            <TextBlock x:Name="HomeLogoPathText" Visibility="Collapsed"/>
                            <TextBlock x:Name="AwayLogoPathText" Visibility="Collapsed"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- ═══ NAVIGATION SIGNPOSTS ═══ -->
                                <Border Grid.Row="0" Background="#0D1117" Padding="20,0" BorderBrush="#21262D" BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Teams_Click" Background="Transparent">
                                            <TextBlock Text="TEAMS" FontSize="11" FontWeight="Black" Foreground="#58A6FF"/>
                                        </Border>
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Match_Click" Background="Transparent">
                                            <TextBlock Text="MATCH" FontSize="11" FontWeight="Black" Foreground="#D29922"/>
                                        </Border>
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Display_Click" Background="Transparent">
                                            <TextBlock Text="DISPLAY" FontSize="11" FontWeight="Black" Foreground="#58A6FF"/>
                                        </Border>
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Overlays_Click" Background="Transparent">
                                            <TextBlock Text="OVERLAYS" FontSize="11" FontWeight="Black" Foreground="#3FB950"/>
                                        </Border>
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Media_Click" Background="Transparent">
                                            <TextBlock Text="MEDIA" FontSize="11" FontWeight="Black" Foreground="#58A6FF"/>
                                        </Border>
                                        <Border Padding="14,10" Cursor="Hand" MouseLeftButtonUp="SettingsNav_Advanced_Click" Background="Transparent">
                                            <TextBlock Text="ADVANCED" FontSize="11" FontWeight="Black" Foreground="#8B949E"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ═══ SCROLLABLE SETTINGS CONTENT ═══ -->
                                <ScrollViewer x:Name="SettingsScrollViewer" Grid.Row="1" Margin="20,16,20,16" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <StackPanel>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 1: TEAMS                      -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Teams" Margin="0,0,0,24">
                                        <StackPanel>
                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="TEAMS" FontSize="14" FontWeight="Black" Foreground="#58A6FF" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#58A6FF" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Edit team names, abbreviations, colours, and logos" FontSize="9" FontWeight="SemiBold" Foreground="#3A5A80"/>
                                            </StackPanel>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Home team card -->
                                                <Border Grid.Column="0" Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1,2,1,1" Padding="14,10">
                                                    <Grid>
                                                        <Border Opacity="0.06" IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <RadialGradientBrush Center="0.5,0.3" RadiusX="0.6" RadiusY="0.5">
                                                                    <GradientStop Color="#58A6FF" Offset="0"/>
                                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <StackPanel>
                                                            <Border Background="#1A3A6A" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                                <TextBlock Text="HOME TEAM" Foreground="#7EB4FF" FontSize="10" FontWeight="Black"/>
                                                            </Border>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox x:Name="HomeNameBox" Text="Home Team" FontSize="12" Background="#0A1018" Foreground="#E6EDF3" BorderBrush="#1E3050" BorderThickness="1" CaretBrush="White" Padding="10,7" VerticalContentAlignment="Center" TextChanged="TeamSettings_TextChanged"/>
                                                                <TextBox x:Name="HomeAbbrBox" Grid.Column="2" Text="HOM" FontSize="12" Background="#0A1018" Foreground="#E6EDF3" BorderBrush="#1E3050" BorderThickness="1" CaretBrush="White" Padding="6,7" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLength="4" TextChanged="TeamSettings_TextChanged"/>
                                                            </Grid>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBox x:Name="HomeColorBox" Width="66" Text="#0A2A6A" FontSize="10" VerticalContentAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                                                <Border x:Name="HomeColorPreview" Width="30" Height="28" Background="#0A2A6A" BorderBrush="#3A5070" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickHomeColor_Click"/>
                                                                <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperHomeColor_Click" Margin="3,0,0,0">
                                                                    <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBox x:Name="HomeSecondaryColorBox" Width="66" Text="#FFFFFF" FontSize="10" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                                                                <Border x:Name="HomeSecondaryColorPreview" Width="30" Height="28" Background="#FFFFFF" BorderBrush="#3A5070" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickHomeSecondaryColor_Click" Margin="8,0,0,0"/>
                                                                <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperHomeSecondaryColor_Click" Margin="3,0,0,0">
                                                                    <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="Primary" Foreground="#3A5070" FontSize="8" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                                <TextBlock Text="/ Text" Foreground="#3A5070" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <Button Content="📂 Logo" Height="26" FontSize="10" FontWeight="Bold" Click="BrowseHomeLogo_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A6A" Padding="8,0"/>
                                                                <Button Content="✕" Width="26" Height="26" FontSize="10" FontWeight="Bold" Click="ClearHomeLogo_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A2020" Margin="4,0,0,0" ToolTip="Remove logo"/>
                                                                <TextBlock x:Name="HomeLogoStatusText" Text="" Foreground="#3A5070" FontSize="9" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Away team card -->
                                                <Border Grid.Column="2" Background="#1A0A0A" BorderBrush="#6A1A1A" BorderThickness="1,2,1,1" Padding="14,10">
                                                    <Grid>
                                                        <Border Opacity="0.06" IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <RadialGradientBrush Center="0.5,0.3" RadiusX="0.6" RadiusY="0.5">
                                                                    <GradientStop Color="#FF6B6B" Offset="0"/>
                                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <StackPanel>
                                                            <Border Background="#4A1A1A" Padding="8,3" HorizontalAlignment="Left" Margin="0,0,0,8">
                                                                <TextBlock Text="AWAY TEAM" Foreground="#FF9A9A" FontSize="10" FontWeight="Black"/>
                                                            </Border>
                                                            <Grid Margin="0,0,0,6">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="8"/>
                                                                    <ColumnDefinition Width="70"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBox x:Name="AwayNameBox" Text="Away Team" FontSize="12" Background="#0A1018" Foreground="#E6EDF3" BorderBrush="#1E3050" BorderThickness="1" CaretBrush="White" Padding="10,7" VerticalContentAlignment="Center" TextChanged="TeamSettings_TextChanged"/>
                                                                <TextBox x:Name="AwayAbbrBox" Grid.Column="2" Text="AWA" FontSize="12" Background="#0A1018" Foreground="#E6EDF3" BorderBrush="#1E3050" BorderThickness="1" CaretBrush="White" Padding="6,7" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" MaxLength="4" TextChanged="TeamSettings_TextChanged"/>
                                                            </Grid>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBox x:Name="AwayColorBox" Width="66" Text="#7A1A1A" FontSize="10" VerticalContentAlignment="Center" Margin="0,0,3,0" Visibility="Collapsed"/>
                                                                <Border x:Name="AwayColorPreview" Width="30" Height="28" Background="#7A1A1A" BorderBrush="#3A5070" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickAwayColor_Click"/>
                                                                <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperAwayColor_Click" Margin="3,0,0,0">
                                                                    <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBox x:Name="AwaySecondaryColorBox" Width="66" Text="#FFFFFF" FontSize="10" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                                                                <Border x:Name="AwaySecondaryColorPreview" Width="30" Height="28" Background="#FFFFFF" BorderBrush="#3A5070" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickAwaySecondaryColor_Click" Margin="8,0,0,0"/>
                                                                <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperAwaySecondaryColor_Click" Margin="3,0,0,0">
                                                                    <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="Primary" Foreground="#523030" FontSize="8" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                                                <TextBlock Text="/ Text" Foreground="#523030" FontSize="8" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <Button Content="📂 Logo" Height="26" FontSize="10" FontWeight="Bold" Click="BrowseAwayLogo_Click" Style="{StaticResource ToolBtn}" BorderBrush="#4A1A1A" Padding="8,0"/>
                                                                <Button Content="✕" Width="26" Height="26" FontSize="10" FontWeight="Bold" Click="ClearAwayLogo_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A2020" Margin="4,0,0,0" ToolTip="Remove logo"/>
                                                                <TextBlock x:Name="AwayLogoStatusText" Text="" Foreground="#523030" FontSize="9" VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 2: MATCH                      -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Match" Margin="0,0,0,24">
                                        <StackPanel>
                                            <Border Height="1" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#00D29922" Offset="0"/>
                                                        <GradientStop Color="#30D29922" Offset="0.5"/>
                                                        <GradientStop Color="#00D29922" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="MATCH" FontSize="14" FontWeight="Black" Foreground="#D29922" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#D29922" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Clock mode, quarter duration, and finals settings" FontSize="9" FontWeight="SemiBold" Foreground="#6B5A00"/>
                                            </StackPanel>

                                            <!-- Clock mode cards -->
                                            <Grid Margin="0,0,0,8" Height="100">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Count Up card -->
                                                <Border x:Name="SettingsCountUpCard" Grid.Column="0" Cursor="Hand" Background="#0A1628" BorderBrush="#58A6FF" BorderThickness="2" MouseLeftButtonUp="SettingsCountUpCard_Click">
                                                    <Grid>
                                                        <Border x:Name="SettingsCountUpGlow" Opacity="0.12" IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                    <GradientStop Color="#58A6FF" Offset="0"/>
                                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="▲" FontSize="26" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#58A6FF" Opacity="0.5"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                            <TextBlock Text="COUNT UP" FontSize="14" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="SettingsCountUpCheck" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#58A6FF" Padding="6,3">
                                                            <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <!-- Countdown card -->
                                                <Border x:Name="SettingsCountdownCard" Grid.Column="2" Cursor="Hand" Background="#0E0C08" BorderBrush="#3A3018" BorderThickness="1" MouseLeftButtonUp="SettingsCountdownCard_Click">
                                                    <Grid>
                                                        <Border x:Name="SettingsCountdownGlow" Opacity="0" IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                    <GradientStop Color="#D29922" Offset="0"/>
                                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="▼" FontSize="26" FontWeight="Black" Foreground="#6B5A00" HorizontalAlignment="Center"/>
                                                            <TextBlock Text="COUNTDOWN" FontSize="14" FontWeight="Black" Foreground="#8A7A50" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="SettingsCountdownCheck" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="6,3" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Grid>

                                            <!-- Quarter duration panel -->
                                            <StackPanel x:Name="QuarterDurationPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                                <Border Background="#0C0A04" BorderBrush="#3A3018" BorderThickness="1" Padding="14">
                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="QUARTER LENGTH" FontSize="9" FontWeight="Black" Foreground="#8A7A40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Border Background="#141008" BorderBrush="#3A3018" BorderThickness="1" Width="36" Height="36" Cursor="Hand" MouseLeftButtonUp="SettingsMinutesMinus_Click">
                                                                <TextBlock Text="−" FontSize="18" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Background="#0A0804" BorderBrush="#6B5A00" BorderThickness="1" MinWidth="56" Height="52" Padding="0" Margin="6,0">
                                                                <TextBox x:Name="QuarterMinutesBox" Text="20" FontSize="30" FontWeight="Black" FontFamily="Consolas" Foreground="#D29922" Background="Transparent" BorderThickness="0" CaretBrush="#D29922" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="3" KeyDown="QuarterDurationBox_KeyDown">
                                                                    <TextBox.Effect>
                                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#D29922" Opacity="0.3"/>
                                                                    </TextBox.Effect>
                                                                </TextBox>
                                                            </Border>
                                                            <Border Background="#141008" BorderBrush="#3A3018" BorderThickness="1" Width="36" Height="36" Cursor="Hand" MouseLeftButtonUp="SettingsMinutesPlus_Click">
                                                                <TextBlock Text="+" FontSize="18" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text=":" FontSize="30" FontWeight="Black" Foreground="#6B5A00" VerticalAlignment="Center" Margin="8,0"/>
                                                            <Border Background="#141008" BorderBrush="#3A3018" BorderThickness="1" Width="36" Height="36" Cursor="Hand" MouseLeftButtonUp="SettingsSecondsMinus_Click">
                                                                <TextBlock Text="−" FontSize="18" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Background="#0A0804" BorderBrush="#6B5A00" BorderThickness="1" MinWidth="56" Height="52" Padding="0" Margin="6,0">
                                                                <TextBox x:Name="QuarterSecondsBox" Text="00" FontSize="30" FontWeight="Black" FontFamily="Consolas" Foreground="#D29922" Background="Transparent" BorderThickness="0" CaretBrush="#D29922" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="2" KeyDown="QuarterDurationBox_KeyDown">
                                                                    <TextBox.Effect>
                                                                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#D29922" Opacity="0.3"/>
                                                                    </TextBox.Effect>
                                                                </TextBox>
                                                            </Border>
                                                            <Border Background="#141008" BorderBrush="#3A3018" BorderThickness="1" Width="36" Height="36" Cursor="Hand" MouseLeftButtonUp="SettingsSecondsPlus_Click">
                                                                <TextBlock Text="+" FontSize="18" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                                            <TextBlock Text="MINUTES" FontSize="8" FontWeight="SemiBold" Foreground="#6B5A00" Width="128" TextAlignment="Center"/>
                                                            <TextBlock Text="SECONDS" FontSize="8" FontWeight="SemiBold" Foreground="#6B5A00" Width="128" TextAlignment="Center" Margin="16,0,0,0"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock x:Name="ClockStatusText" Text="Count Up · Stopped · 00:00" Foreground="#6B5A00" FontSize="10" Margin="0,0,0,8"/>

                                            <!-- Live clock adjustment -->
                                            <Border Background="#0C0A04" BorderBrush="#3A3018" BorderThickness="1" Padding="10" Margin="0,0,0,8">
                                                <StackPanel>
                                                    <TextBlock Text="ADJUST CLOCK" FontSize="9" FontWeight="Black" Foreground="#8A7A40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <Button Content="−10s" Width="46" Height="28" FontSize="10" FontWeight="Bold" Click="ClockMinus10_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A3018" Margin="0,0,4,0"/>
                                                        <Button Content="−1s" Width="40" Height="28" FontSize="10" FontWeight="Bold" Click="ClockMinus1_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A3018" Margin="0,0,8,0"/>
                                                        <Button Content="+1s" Width="40" Height="28" FontSize="10" FontWeight="Bold" Click="ClockPlus1_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A3018" Margin="0,0,4,0"/>
                                                        <Button Content="+10s" Width="46" Height="28" FontSize="10" FontWeight="Bold" Click="ClockPlus10_Click" Style="{StaticResource ToolBtn}" BorderBrush="#3A3018"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                                        <TextBlock Text="SET:" FontSize="9" FontWeight="Black" Foreground="#6B5A00" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                        <Border Background="#0A0804" BorderBrush="#6B5A00" BorderThickness="1" Width="40" Height="28" Padding="0">
                                                            <TextBox x:Name="ClockSetMinutesBox" Text="00" FontSize="14" FontWeight="Black" FontFamily="Consolas" Foreground="#D29922" Background="Transparent" BorderThickness="0" CaretBrush="#D29922" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="3"/>
                                                        </Border>
                                                        <TextBlock Text=":" FontSize="14" FontWeight="Black" Foreground="#6B5A00" VerticalAlignment="Center" Margin="2,0"/>
                                                        <Border Background="#0A0804" BorderBrush="#6B5A00" BorderThickness="1" Width="34" Height="28" Padding="0">
                                                            <TextBox x:Name="ClockSetSecondsBox" Text="00" FontSize="14" FontWeight="Black" FontFamily="Consolas" Foreground="#D29922" Background="Transparent" BorderThickness="0" CaretBrush="#D29922" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="2"/>
                                                        </Border>
                                                        <Button Content="SET" Width="36" Height="28" FontSize="9" FontWeight="Black" Click="ClockSet_Click" Style="{StaticResource ToolBtn}" BorderBrush="#6B5A00" Foreground="#D29922" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>

                                            <!-- Finals mode -->
                                            <CheckBox x:Name="SettingsFinalsToggle" Checked="SettingsFinalsToggle_Changed" Unchecked="SettingsFinalsToggle_Changed" Visibility="Collapsed"/>
                                            <Border x:Name="SettingsFinalsCard" Background="#0A0806" BorderBrush="#2A2020" BorderThickness="1" Padding="14" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="SettingsFinalsCard_Click">
                                                <Grid>
                                                    <Border x:Name="SettingsFinalsGlow" Opacity="0" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                <GradientStop Color="#D4A017" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="🏆" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock x:Name="SettingsFinalsTitle" Text="FINALS MODE" FontSize="13" FontWeight="Black" Foreground="#5A4A20" Margin="0,0,0,2"/>
                                                            <TextBlock Text="Golden bar styling and time-on after siren in final quarter" FontSize="9" FontWeight="SemiBold" Foreground="#3A3018" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <Grid Width="44" Height="24">
                                                            <Border x:Name="SettingsFinalsTrack" CornerRadius="12" Background="#1A1610" BorderBrush="#3A3018" BorderThickness="1"/>
                                                            <Border x:Name="SettingsFinalsThumb" Width="18" Height="18" CornerRadius="9" Background="#5A4A20" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 3: DISPLAY                    -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Display" Margin="0,0,0,24">
                                        <StackPanel>
                                            <Border Height="1" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#0058A6FF" Offset="0"/>
                                                        <GradientStop Color="#3058A6FF" Offset="0.5"/>
                                                        <GradientStop Color="#0058A6FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="DISPLAY" FontSize="14" FontWeight="Black" Foreground="#58A6FF" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#58A6FF" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Scoreboard layout and goal animation style" FontSize="9" FontWeight="SemiBold" Foreground="#3A5A80"/>
                                            </StackPanel>

                                            <!-- Scoreboard layout (hidden — Classic only) -->
                                            <Grid Visibility="Collapsed">
                                                <Border x:Name="LayoutCardClassic" Background="#0A1628">
                                                    <Grid>
                                                        <Border x:Name="LayoutGlowClassic" Opacity="0.12" IsHitTestVisible="False"/>
                                                        <Border x:Name="LayoutCheckClassic" Visibility="Visible"/>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="LayoutCardExpanded"><Grid><Border x:Name="LayoutCheckExpanded" Visibility="Collapsed"/></Grid></Border>
                                                <Border x:Name="LayoutCardRetro"><Grid><Border x:Name="LayoutCheckRetro" Visibility="Collapsed"/></Grid></Border>
                                                <Border x:Name="LayoutCardNoLogos"><Grid><Border x:Name="LayoutCheckNoLogos" Visibility="Collapsed"/></Grid></Border>
                                            </Grid>

                                            <!-- Goal animation -->
                                            <TextBlock Text="GOAL ANIMATION" FontSize="11" FontWeight="Black" Foreground="#8A7A40" Margin="0,0,0,6"/>
                                            <UniformGrid Columns="3" Margin="0,0,0,4">
                                                <Border x:Name="AnimCardBroadcast" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="0,0,3,3" MouseLeftButtonUp="AnimBroadcastCard_Click">
                                                    <Grid MinHeight="64">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="📡" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="BROADCAST" FontSize="9" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckBroadcast" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="AnimCardElectric" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="0,0,3,3" MouseLeftButtonUp="AnimElectricCard_Click">
                                                    <Grid MinHeight="64">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="⚡" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="ELECTRIC" FontSize="9" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckElectric" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="AnimCardCinematic" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="0,0,0,3" MouseLeftButtonUp="AnimCinematicCard_Click">
                                                    <Grid MinHeight="64">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="🎬" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="CINEMATIC" FontSize="9" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckCinematic" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="AnimCardClean" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="0,0,3,0" MouseLeftButtonUp="AnimCleanCard_Click">
                                                    <Grid MinHeight="64">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="✨" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="CLEAN" FontSize="9" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckClean" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="AnimCardClassic" Cursor="Hand" Background="#0E0E1A" BorderBrush="#2A2A40" BorderThickness="1" Margin="0,0,3,0" MouseLeftButtonUp="AnimClassicCard_Click">
                                                    <Grid MinHeight="64">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="🎞" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="CLASSIC" FontSize="9" FontWeight="Black" Foreground="#6A6A80" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckClassic" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2" Visibility="Collapsed">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <Border x:Name="AnimCardCustomVideo" Cursor="Hand" Background="#1A1408" BorderBrush="#6B5A00" BorderThickness="2" Margin="0" MouseLeftButtonUp="AnimCustomVideoCard_Click">
                                                    <Grid MinHeight="64">
                                                        <Border x:Name="AnimGlowCustomVideo" Opacity="0.12" IsHitTestVisible="False">
                                                            <Border.Background>
                                                                <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                    <GradientStop Color="#D29922" Offset="0"/>
                                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <TextBlock Text="🎥" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                                            <TextBlock Text="CUSTOM" FontSize="9" FontWeight="Black" Foreground="#D29922" HorizontalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Border x:Name="AnimCheckCustomVideo" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#D29922" Padding="4,2">
                                                            <TextBlock Text="✓" FontSize="8" FontWeight="Black" Foreground="#1A1400"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>

                                            <Border BorderBrush="#1A2A40" BorderThickness="1" Background="#0A0E18" Padding="10,8" Margin="0,0,0,4">
                                                <StackPanel>
                                                    <TextBlock x:Name="AnimPreviewTitle" Text="Custom Video" Foreground="White" FontSize="11" FontWeight="Bold" Margin="0,0,0,2"/>
                                                    <TextBlock x:Name="AnimPreviewDesc" Text="Team-specific goal video playback if configured." Foreground="#6B5A00" FontSize="9" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border BorderBrush="#3A3018" BorderThickness="1" Background="#0C0A04" Padding="6,2" Margin="0,0,6,0">
                                                            <TextBlock x:Name="AnimPreviewDuration" Text="Video" Foreground="#8A7A40" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                        <Border BorderBrush="#3A3018" BorderThickness="1" Background="#0C0A04" Padding="6,2">
                                                            <TextBlock x:Name="AnimPreviewIntensity" Text="Custom" Foreground="#8A7A40" FontSize="9" FontWeight="Bold"/>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 4: OVERLAYS                   -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Overlays" Margin="0,0,0,24">
                                        <StackPanel>
                                            <Border Height="1" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#003FB950" Offset="0"/>
                                                        <GradientStop Color="#303FB950" Offset="0.5"/>
                                                        <GradientStop Color="#003FB950" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="OVERLAYS" FontSize="14" FontWeight="Black" Foreground="#3FB950" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#3FB950" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Automatic overlays, break screen, and weather" FontSize="9" FontWeight="SemiBold" Foreground="#2A6030"/>
                                            </StackPanel>

                                            <!-- Auto overlays -->
                                            <CheckBox x:Name="AutoOverlaysToggle" IsChecked="True" Checked="AutoOverlaysToggle_Changed" Unchecked="AutoOverlaysToggle_Changed" Visibility="Collapsed"/>
                                            <Border x:Name="AutoOverlaysCard" Background="#0A1410" BorderBrush="#3FB950" BorderThickness="2" Padding="14" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="AutoOverlaysCard_Click">
                                                <Grid>
                                                    <Border x:Name="AutoOverlaysGlow" Opacity="0.12" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                <GradientStop Color="#3FB950" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock Text="AUTOMATIC OVERLAYS" FontSize="13" FontWeight="Black" Foreground="#3FB950" Margin="0,0,0,4">
                                                            <TextBlock.Effect>
                                                                <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#3FB950" Opacity="0.3"/>
                                                            </TextBlock.Effect>
                                                        </TextBlock>
                                                        <TextBlock Text="Periodic stats, win probability, weather, and scoring run overlays on the scorebug" FontSize="9" FontWeight="SemiBold" Foreground="#2A6030" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <Border x:Name="AutoOverlaysCheck" HorizontalAlignment="Right" VerticalAlignment="Top" Background="#3FB950" Padding="6,3">
                                                        <TextBlock Text="✓" FontSize="9" FontWeight="Black" Foreground="White"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Break screen -->
                                            <CheckBox x:Name="SettingsBreakScreenToggle" IsChecked="True" Checked="SettingsBreakScreenToggle_Changed" Unchecked="SettingsBreakScreenToggle_Changed" Visibility="Collapsed"/>
                                            <Border x:Name="SettingsBreakScreenCard" Background="#060A14" BorderBrush="#1A2A50" BorderThickness="1" Padding="14" Margin="0,0,0,8" Cursor="Hand" MouseLeftButtonUp="SettingsBreakScreenCard_Click">
                                                <Grid>
                                                    <Border x:Name="SettingsBreakScreenGlow" Opacity="0.10" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                                <GradientStop Color="#58A6FF" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="⏸" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock x:Name="SettingsBreakScreenTitle" Text="QUARTER BREAK SCREEN" FontSize="13" FontWeight="Black" Foreground="#58A6FF" Margin="0,0,0,2"/>
                                                            <TextBlock Text="Auto-show summary screen at quarter breaks" FontSize="9" FontWeight="SemiBold" Foreground="#2A4A70" TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <Border HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                                                        <Grid Width="44" Height="24">
                                                            <Border x:Name="SettingsBreakScreenTrack" CornerRadius="12" Background="#0A1628" BorderBrush="#58A6FF" BorderThickness="1"/>
                                                            <Border x:Name="SettingsBreakScreenThumb" Width="18" Height="18" CornerRadius="9" Background="#58A6FF" HorizontalAlignment="Right" Margin="0,0,3,0"/>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Weather -->
                                            <Border Background="#080E1A" BorderBrush="#1A3060" BorderThickness="1" Padding="14" Margin="0,0,0,4">
                                                <Grid>
                                                    <Border Opacity="0.06" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.4" RadiusX="0.5" RadiusY="0.5">
                                                                <GradientStop Color="#58A6FF" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                            <TextBlock Text="☁" FontSize="20" Margin="0,0,8,0"/>
                                                            <TextBlock Text="LIVE WEATHER" FontSize="13" FontWeight="Black" Foreground="#58A6FF" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ComboBox x:Name="SettingsWeatherLocation" IsEditable="True" IsTextSearchEnabled="False" MaxDropDownHeight="200" StaysOpenOnEdit="True" FontSize="12" Foreground="Black" BorderBrush="#2A4A70" Padding="8,5" VerticalContentAlignment="Center"/>
                                                            <Button Grid.Column="2" Content="Apply" Width="60" Height="30" FontSize="11" FontWeight="Bold" Click="ApplyWeatherLocation_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3060"/>
                                                        </Grid>
                                                        <TextBlock x:Name="WeatherLocationStatus" Text="" Foreground="#3A6090" FontSize="10" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 5: MEDIA                      -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Media" Margin="0,0,0,24">
                                        <StackPanel>
                                            <Border Height="1" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#0058A6FF" Offset="0"/>
                                                        <GradientStop Color="#2058A6FF" Offset="0.5"/>
                                                        <GradientStop Color="#0058A6FF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="MEDIA" FontSize="14" FontWeight="Black" Foreground="#58A6FF" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#58A6FF" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Adjust logo crop and positioning" FontSize="9" FontWeight="SemiBold" Foreground="#3A5A80"/>
                                            </StackPanel>

                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1" Padding="8">
                                                    <StackPanel>
                                                        <TextBlock Text="HOME" Foreground="#7EB4FF" FontSize="9" FontWeight="Black" Margin="0,0,0,4"/>
                                                        <Border Height="70" Margin="0,0,0,6" BorderBrush="#1A3A6A" BorderThickness="1" Background="#060A10" ClipToBounds="True">
                                                            <Grid>
                                                                <Image x:Name="HomeLogoCropPreviewImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="Zoom" Foreground="#3A5070" FontSize="8"/>
                                                        <Slider x:Name="HomeLogoZoomSlider" Minimum="0.8" Maximum="3.0" Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <TextBlock Text="X" Foreground="#3A5070" FontSize="8" Margin="0,2,0,0"/>
                                                        <Slider x:Name="HomeLogoXSlider" Minimum="-50" Maximum="50" Value="0" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <TextBlock Text="Y" Foreground="#3A5070" FontSize="8" Margin="0,2,0,0"/>
                                                        <Slider x:Name="HomeLogoYSlider" Minimum="-50" Maximum="50" Value="0" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <Button Content="Reset Home" Height="24" Margin="0,4,0,0" Click="ResetHomeCrop_Click" Style="{StaticResource ToolBtn}" FontSize="10" BorderBrush="#1A3A6A"/>
                                                    </StackPanel>
                                                </Border>

                                                <Border Grid.Column="2" Background="#1A0A0A" BorderBrush="#4A1A1A" BorderThickness="1" Padding="8">
                                                    <StackPanel>
                                                        <TextBlock Text="AWAY" Foreground="#FF9A9A" FontSize="9" FontWeight="Black" Margin="0,0,0,4"/>
                                                        <Border Height="70" Margin="0,0,0,6" BorderBrush="#4A1A1A" BorderThickness="1" Background="#060A10" ClipToBounds="True">
                                                            <Grid>
                                                                <Image x:Name="AwayLogoCropPreviewImage" Stretch="Uniform" RenderTransformOrigin="0.5,0.5"/>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="Zoom" Foreground="#523030" FontSize="8"/>
                                                        <Slider x:Name="AwayLogoZoomSlider" Minimum="0.8" Maximum="3.0" Value="1.0" TickFrequency="0.05" IsSnapToTickEnabled="True" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <TextBlock Text="X" Foreground="#523030" FontSize="8" Margin="0,2,0,0"/>
                                                        <Slider x:Name="AwayLogoXSlider" Minimum="-50" Maximum="50" Value="0" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <TextBlock Text="Y" Foreground="#523030" FontSize="8" Margin="0,2,0,0"/>
                                                        <Slider x:Name="AwayLogoYSlider" Minimum="-50" Maximum="50" Value="0" ValueChanged="LogoCropSlider_ValueChanged"/>
                                                        <Button Content="Reset Away" Height="24" Margin="0,4,0,0" Click="ResetAwayCrop_Click" Style="{StaticResource ToolBtn}" FontSize="10" BorderBrush="#4A1A1A"/>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                            <TextBlock x:Name="LogoCropSummaryText" Foreground="#5080AA" FontSize="9" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ══════════════════════════════════════ -->
                                    <!-- SECTION 6: ADVANCED                   -->
                                    <!-- ══════════════════════════════════════ -->
                                    <Border x:Name="SettingsSection_Advanced" Margin="0,0,0,12">
                                        <StackPanel>
                                            <Border Height="1" Margin="0,0,0,14">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#008B949E" Offset="0"/>
                                                        <GradientStop Color="#208B949E" Offset="0.5"/>
                                                        <GradientStop Color="#008B949E" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>

                                            <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                                <TextBlock Text="ADVANCED" FontSize="14" FontWeight="Black" Foreground="#8B949E" Margin="0,0,0,2">
                                                    <TextBlock.Effect>
                                                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#8B949E" Opacity="0.3"/>
                                                    </TextBlock.Effect>
                                                </TextBlock>
                                                <TextBlock Text="Window dimensions, web access, and reset" FontSize="9" FontWeight="SemiBold" Foreground="#484F58"/>
                                            </StackPanel>

                                            <!-- Window dimensions -->
                                            <TextBlock Text="WINDOW DIMENSIONS" FontSize="11" FontWeight="Black" Foreground="#5080AA" Margin="0,0,0,8"/>
                                            <Border Background="#0A0E18" BorderBrush="#1A2A40" BorderThickness="1" Padding="14" Margin="0,0,0,4">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="20"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel HorizontalAlignment="Center">
                                                        <TextBlock Text="WIDTH" FontSize="8" FontWeight="Black" Foreground="#5080AA" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Border Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1" Width="32" Height="32" Cursor="Hand" MouseLeftButtonUp="WidthMinus_Click">
                                                                <TextBlock Text="−" FontSize="16" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Background="#060A10" BorderBrush="#2A4A70" BorderThickness="1" MinWidth="60" Height="44" Padding="0" Margin="4,0">
                                                                <TextBox x:Name="WindowWidthBox" Text="386" FontSize="22" FontWeight="Black" FontFamily="Consolas" Foreground="#58A6FF" Background="Transparent" BorderThickness="0" CaretBrush="#58A6FF" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="5"/>
                                                            </Border>
                                                            <Border Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1" Width="32" Height="32" Cursor="Hand" MouseLeftButtonUp="WidthPlus_Click">
                                                                <TextBlock Text="+" FontSize="16" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="px" FontSize="8" Foreground="#3A5070" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                        <TextBlock Text="HEIGHT" FontSize="8" FontWeight="BLACK" Foreground="#5080AA" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                            <Border Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1" Width="32" Height="32" Cursor="Hand" MouseLeftButtonUp="HeightMinus_Click">
                                                                <TextBlock Text="−" FontSize="16" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <Border Background="#060A10" BorderBrush="#2A4A70" BorderThickness="1" MinWidth="60" Height="44" Padding="0" Margin="4,0">
                                                                <TextBox x:Name="WindowHeightBox" Text="193" FontSize="22" FontWeight="Black" FontFamily="Consolas" Foreground="#58A6FF" Background="Transparent" BorderThickness="0" CaretBrush="#58A6FF" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" MaxLength="5"/>
                                                            </Border>
                                                            <Border Background="#0A1628" BorderBrush="#1A3A6A" BorderThickness="1" Width="32" Height="32" Cursor="Hand" MouseLeftButtonUp="HeightPlus_Click">
                                                                <TextBlock Text="+" FontSize="16" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="px" FontSize="8" Foreground="#3A5070" HorizontalAlignment="Center" Margin="0,3,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                            <Button Content="APPLY SIZE" Height="32" FontSize="11" FontWeight="Black" Click="ApplyWindowDimensions_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A6A" Foreground="#58A6FF" Margin="0,4,0,2"/>
                                            <TextBlock x:Name="WindowDimensionsStatus" Text="" Foreground="#3A5A80" FontSize="10" Margin="0,0,0,12"/>

                                            <!-- Web access -->
                                            <TextBlock Text="WEB ACCESS" FontSize="11" FontWeight="Black" Foreground="#3A8040" Margin="0,0,0,8"/>
                                            <Border Background="#0A1410" BorderBrush="#1A3A24" BorderThickness="1" Padding="14" Margin="0,0,0,12">
                                                <Grid>
                                                    <Border Opacity="0.05" IsHitTestVisible="False">
                                                        <Border.Background>
                                                            <RadialGradientBrush Center="0.5,0.3" RadiusX="0.5" RadiusY="0.5">
                                                                <GradientStop Color="#3FB950" Offset="0"/>
                                                                <GradientStop Color="#00000000" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                    <StackPanel>
                                                        <TextBlock x:Name="WebAccessStatus" Text="Starting web server…" Foreground="#5AAA68" FontSize="10" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                                        <TextBlock Text="LIVE VIEW" Foreground="#3A6030" FontSize="9" FontWeight="Black" Margin="0,0,0,4"/>
                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="WebLiveUrlBox" IsReadOnly="True" FontSize="11" FontFamily="Consolas" Background="#060A10" Foreground="#58A6FF" BorderBrush="#1A3A24" Padding="8,5" VerticalContentAlignment="Center" Text="—" Cursor="IBeam"/>
                                                            <Button Grid.Column="1" Content="📋" Width="32" Height="28" FontSize="13" Margin="4,0,0,0" Click="CopyLiveUrl_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A24"/>
                                                        </Grid>

                                                        <TextBlock Text="REMOTE CONTROL" Foreground="#3A6030" FontSize="9" FontWeight="Black" Margin="0,0,0,4"/>
                                                        <Grid Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox x:Name="WebControlUrlBox" IsReadOnly="True" FontSize="11" FontFamily="Consolas" Background="#060A10" Foreground="#58A6FF" BorderBrush="#1A3A24" Padding="8,5" VerticalContentAlignment="Center" Text="—" Cursor="IBeam"/>
                                                            <Button Grid.Column="1" Content="📋" Width="32" Height="28" FontSize="13" Margin="4,0,0,0" Click="CopyControlUrl_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A24"/>
                                                        </Grid>
                                                        <TextBlock Text="Share these links with anyone on the same Wi-Fi network." Foreground="#2A5030" FontSize="9" TextWrapping="Wrap"/>

                                                        <!-- QR Codes -->
                                                        <Grid Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="12"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                <TextBlock Text="LIVE VIEW" Foreground="#3A6030" FontSize="8" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                                <Border Background="#0D1117" BorderBrush="#1A3A24" BorderThickness="1" Padding="4">
                                                                    <Image x:Name="LiveQrImage" Width="100" Height="100" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                                </Border>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                <TextBlock Text="REMOTE CONTROL" Foreground="#3A6030" FontSize="8" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                                                <Border Background="#0D1117" BorderBrush="#1A3A24" BorderThickness="1" Padding="4">
                                                                    <Image x:Name="ControlQrImage" Width="100" Height="100" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Reset -->
                                            <Border Background="#1C0A0A" BorderBrush="#4A2020" BorderThickness="1" Padding="14" Cursor="Hand" MouseLeftButtonUp="ResetCardSettings_Click">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="⟲" FontSize="28" HorizontalAlignment="Center" Foreground="#FF6B6B" Margin="0,0,0,4"/>
                                                    <TextBlock Text="RESET MATCH" FontSize="14" FontWeight="Black" Foreground="#FF6B6B" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Clear all and start over" FontSize="9" Foreground="#6B3A3E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- ═══════════════════════════════════ -->
                                            <!-- APP UPDATE                          -->
                                            <!-- ═══════════════════════════════════ -->
                                            <Border Background="#0A1620" BorderBrush="#1A3A6A" BorderThickness="1" Padding="14" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="⬆" FontSize="28" HorizontalAlignment="Center" Foreground="#58A6FF" Margin="0,0,0,4"/>
                                                    <TextBlock Text="APP UPDATE" FontSize="14" FontWeight="Black" Foreground="#58A6FF" HorizontalAlignment="Center"/>
                                                    <TextBlock x:Name="UpdateCurrentVersionText" Text="Current version: …" FontSize="10" Foreground="#6E7B8A" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                                    <TextBlock x:Name="UpdateStatusText" Text="Click 'Check for updates' to look for a new version." FontSize="11" FontWeight="SemiBold" Foreground="#8A95A3" HorizontalAlignment="Center" Margin="0,4,0,8" TextWrapping="Wrap" TextAlignment="Center"/>

                                                    <ProgressBar x:Name="UpdateProgressBar" Height="6" Minimum="0" Maximum="100" Value="0" Visibility="Collapsed" Margin="0,0,0,8" Foreground="#58A6FF" Background="#0D1117"/>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="8"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Button x:Name="CheckForUpdateButton" Grid.Column="0" Content="Check for updates" Height="30" FontSize="11" FontWeight="Bold" Click="CheckForUpdate_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A6A" Foreground="#58A6FF"/>
                                                        <Button x:Name="InstallUpdateButton" Grid.Column="2" Content="Download &amp; install" Height="30" FontSize="11" FontWeight="Bold" Click="InstallUpdate_Click" Style="{StaticResource ToolBtn}" BorderBrush="#1A3A24" Foreground="#3FB950" Visibility="Collapsed"/>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>

                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ══════════════════════════════════════════ -->
        <!-- RESET CONFIRMATION OVERLAY — cinematic     -->
        <!-- ══════════════════════════════════════════ -->
        <Border x:Name="ResetOverlay" Panel.ZIndex="50" Visibility="Collapsed" Background="#CC000000" Opacity="0">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#0D1117" BorderBrush="#6B3A3E" BorderThickness="2" Padding="0" MinWidth="500" MaxWidth="560">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Top danger stripe -->
                        <Border Grid.Row="0" Background="#F85149" Height="4"/>

                        <!-- Warning icon + title -->
                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="40,32,40,0">
                            <TextBlock Text="⚠" FontSize="48" HorizontalAlignment="Center" Foreground="#F85149" Margin="0,0,0,12"/>
                            <TextBlock Text="RESET MATCH" FontSize="22" FontWeight="Black" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <!-- Description -->
                        <TextBlock Grid.Row="2" TextAlignment="Center" Margin="40,14,40,0" FontSize="13" Foreground="#8B949E" TextWrapping="Wrap"
                                   LineHeight="20">
                            All scores, events, and clock data will be permanently cleared. You'll return to the sport selection screen to start a new match.
                        </TextBlock>

                        <!-- Danger highlight -->
                        <Border Grid.Row="3" Margin="40,18,40,0" Background="#1C0A0A" BorderBrush="#4A2020" BorderThickness="1" Padding="14,10">
                            <TextBlock Text="This action cannot be undone." FontSize="12" FontWeight="Bold" Foreground="#FF9A9A" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Buttons -->
                        <Grid Grid.Row="4" Margin="40,24,40,32">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" x:Name="CancelResetBtn" Content="CANCEL" Height="46" FontSize="14" FontWeight="Black"
                                    Click="CancelReset_Click" Style="{StaticResource ToolBtn}"
                                    Background="#21262D" BorderBrush="#484F58" Foreground="White" Cursor="Hand"/>
                            <Button Grid.Column="2" x:Name="ConfirmResetBtn" Content="RESET" Height="46" FontSize="14" FontWeight="Black"
                                    Click="ConfirmReset_Click" Style="{StaticResource PrimaryCommandButton}"
                                    Background="#9B2C2C" BorderBrush="#F85149" Foreground="White" Cursor="Hand"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════ -->
        <!-- OVERLAY VIEWS — layered Z-order            -->
        <!-- ══════════════════════════════════════════ -->
        <!-- ══════════════════════════════════════════ -->
        <!-- RESIZE GRIP — custom, native Win32 resize   -->
        <!-- ══════════════════════════════════════════ -->
        <Border x:Name="ResizeGripVisual" Panel.ZIndex="300"
                Width="18" Height="18" Margin="0,0,1,1"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="Transparent" Cursor="SizeNWSE"
                MouseLeftButtonDown="ResizeGrip_MouseDown">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Opacity" Value="0.15"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Path Stroke="#8B949E" StrokeThickness="1.5"
                  Data="M 16,4 L 4,16 M 16,9 L 9,16 M 16,14 L 14,16"/>
        </Border>

        <views:SetupWizard x:Name="SetupWizardPanel" Panel.ZIndex="100" Visibility="Collapsed"/>
        <views:CricketControlPanel x:Name="CricketControlPanelView" Panel.ZIndex="0" Visibility="Collapsed"/>
        <views:CricketSetupWizard x:Name="CricketSetupWizardPanel" Panel.ZIndex="100" Visibility="Collapsed"/>
        <views:TrainingControlPanel x:Name="TrainingControlPanelView" Panel.ZIndex="0" Visibility="Collapsed"/>
        <views:SportSelectionScreen x:Name="SportSelectionPanel" Panel.ZIndex="200"/>
    </Grid>
</Window>
