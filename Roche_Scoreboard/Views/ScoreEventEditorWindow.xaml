<Window x:Class="Roche_Scoreboard.Views.ScoreEventEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Score Event"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="360"
        Background="#161B22"
        Foreground="#E6EDF3"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow">

    <StackPanel Margin="18,16,18,18">
        <!-- Header -->
        <TextBlock Text="EDIT SCORE EVENT" Foreground="#58A6FF" FontSize="11" FontWeight="Black" Margin="0,0,0,14"/>

        <!-- Event info (read-only) -->
        <Border Background="#0D1117" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="12,10" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="EventInfoText" Text="Q1 02:15" Foreground="#8B949E" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="EventScoreText" Text="After: 2.3.15 – 1.2.8" Foreground="#6B7E95" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>
        </Border>

        <!-- Time editor -->
        <TextBlock Text="TIME IN QUARTER" Foreground="#8B949E" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="MinutesBox" Grid.Column="0" Text="00" MaxLength="2"
                     Background="#0D1117" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                     FontSize="20" FontWeight="Bold" FontFamily="Bahnschrift" TextAlignment="Center"
                     VerticalContentAlignment="Center" Padding="4,6" CaretBrush="#58A6FF"/>
            <TextBlock Grid.Column="1" Text=":" Foreground="#6B7E95" FontSize="20" FontWeight="Bold"
                       VerticalAlignment="Center" Margin="6,0"/>
            <TextBox x:Name="SecondsBox" Grid.Column="2" Text="00" MaxLength="2"
                     Background="#0D1117" Foreground="#E6EDF3" BorderBrush="#30363D" BorderThickness="1"
                     FontSize="20" FontWeight="Bold" FontFamily="Bahnschrift" TextAlignment="Center"
                     VerticalContentAlignment="Center" Padding="4,6" CaretBrush="#58A6FF"/>
        </Grid>

        <!-- Team selector -->
        <TextBlock Text="TEAM" Foreground="#8B949E" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="HomeTeamBtn" Grid.Column="0" CornerRadius="6" Padding="12,10"
                    Cursor="Hand" MouseLeftButtonUp="HomeTeam_Click"
                    Background="#0D1117" BorderBrush="#30363D" BorderThickness="2">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#58A6FF" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="HOME" Foreground="#6B7E95" FontSize="9" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock x:Name="HomeTeamLabel" Text="Home" Foreground="#E6EDF3" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                </StackPanel>
            </Border>

            <Border x:Name="AwayTeamBtn" Grid.Column="2" CornerRadius="6" Padding="12,10"
                    Cursor="Hand" MouseLeftButtonUp="AwayTeam_Click"
                    Background="#0D1117" BorderBrush="#30363D" BorderThickness="2">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="&#xE128;" FontFamily="Segoe MDL2 Assets" FontSize="22"
                               Foreground="#FF7755" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="AWAY" Foreground="#6B7E95" FontSize="9" FontWeight="Black" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                    <TextBlock x:Name="AwayTeamLabel" Text="Away" Foreground="#E6EDF3" FontSize="13" FontWeight="Bold"
                               HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="130"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Type selector -->
        <TextBlock Text="TYPE" Foreground="#8B949E" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="GoalBtn" Grid.Column="0" CornerRadius="6" Padding="12,10"
                    Cursor="Hand" MouseLeftButtonUp="Goal_Click"
                    Background="#0D1117" BorderBrush="#30363D" BorderThickness="2">
                <StackPanel HorizontalAlignment="Center">
                    <Ellipse Width="20" Height="20" Fill="#3FB950" HorizontalAlignment="Center" Margin="0,2,0,6"/>
                    <TextBlock Text="GOAL" Foreground="#E6EDF3" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="6 PTS" Foreground="#6B7E95" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border x:Name="BehindBtn" Grid.Column="2" CornerRadius="6" Padding="12,10"
                    Cursor="Hand" MouseLeftButtonUp="Behind_Click"
                    Background="#0D1117" BorderBrush="#30363D" BorderThickness="2">
                <StackPanel HorizontalAlignment="Center">
                    <Ellipse Width="20" Height="20" Stroke="#D29922" StrokeThickness="2.5" Fill="Transparent"
                             HorizontalAlignment="Center" Margin="0,2,0,6"/>
                    <TextBlock Text="BEHIND" Foreground="#E6EDF3" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="1 PT" Foreground="#6B7E95" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Action buttons -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="DELETE" Click="Delete_Click"
                    Background="#2A1416" Foreground="#F85149" BorderBrush="#6B3A3E" BorderThickness="1"
                    FontSize="12" FontWeight="Bold" Padding="14,8" Cursor="Hand"/>

            <Button Grid.Column="2" Content="SAVE" Click="Save_Click"
                    Background="#0D2818" Foreground="#3FB950" BorderBrush="#2B6E3F" BorderThickness="1"
                    FontSize="12" FontWeight="Bold" Padding="14,8" Cursor="Hand" IsDefault="True"/>

            <Button Grid.Column="4" Content="CANCEL" Click="Cancel_Click"
                    Background="#21262D" Foreground="#8B949E" BorderBrush="#30363D" BorderThickness="1"
                    FontSize="12" FontWeight="Bold" Padding="14,8" Cursor="Hand" IsCancel="True"/>
        </Grid>
    </StackPanel>
</Window>
