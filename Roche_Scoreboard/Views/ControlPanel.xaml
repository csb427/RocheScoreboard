<UserControl x:Class="Roche_Scoreboard.Views.ControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#0D1117">
    <UserControl.Resources>
        <!-- ═══ COLOUR SYSTEM — broadcast console ═══ -->
        <SolidColorBrush x:Key="ShellBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="RegionBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="RegionEdgeBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMidBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#484F58"/>
        <SolidColorBrush x:Key="HomeAccentBrush" Color="#58A6FF"/>
        <SolidColorBrush x:Key="AwayAccentBrush" Color="#F85149"/>
        <SolidColorBrush x:Key="LiveBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#D29922"/>

        <!-- ── Section heading ── -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── Primary command button — scoring, with tactile feedback ── -->
        <Style x:Key="ScoreButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Padding" Value="0,14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="Sc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0.65" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tool button — compact, hover glow ── -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="TbSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Styled ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1C2128"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>
    </UserControl.Resources>

    <!-- Master Viewbox: at the natural design size (1500×900) the layout is
         identical to before. If the host window is smaller, the entire
         control panel scales DOWN proportionally so it always fits. -->
    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Grid Width="1500" Height="900">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- match strip -->
                <RowDefinition Height="*"/>     <!-- main content -->
            </Grid.RowDefinitions>

        <!-- ═══ PERSISTENT MATCH STRIP ═══ -->
        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,0,2" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status badge -->
                <Border Grid.Column="0" BorderBrush="#244A34" BorderThickness="1.5" Background="#0D2818" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3FB950" Margin="0,0,6,0"/>
                        <TextBlock Text="READY" Foreground="#3FB950" FontSize="11" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <!-- Home team -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="HomeTeamName" Text="Home" Foreground="{StaticResource HomeAccentBrush}" FontWeight="Black" FontSize="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="HomeScore" Text="0" Foreground="White" FontWeight="Black" FontSize="30" FontFamily="Consolas" VerticalAlignment="Center" Margin="14,0,0,0"/>
                </StackPanel>

                <!-- Centre: timer + quarter -->
                <StackPanel Grid.Column="3" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="Timer" Text="00:00" Foreground="{StaticResource WarnBrush}" FontWeight="Black" FontSize="28" FontFamily="Consolas" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Away team -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock x:Name="AwayScore" Text="0" Foreground="White" FontWeight="Black" FontSize="30" FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <TextBlock x:Name="AwayTeamName" Text="Away" Foreground="{StaticResource AwayAccentBrush}" FontWeight="Black" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Quarter badge -->
                <Border Grid.Column="6" BorderBrush="#30363D" BorderThickness="1" Background="#161B22" Padding="12,4">
                    <TextBlock x:Name="QuarterBadgeText" Text="Q1" Foreground="{StaticResource TextMidBrush}" FontSize="14" FontWeight="Black"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Border Grid.Row="1" Background="{StaticResource RegionBrush}" Padding="16,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="280" MinWidth="240"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: Scoring + Clock -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section heading -->
                    <TextBlock Grid.Row="0" Text="SCORING" Style="{StaticResource SectionHead}"/>

                    <!-- Scoring panels — team-coloured zones -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- HOME scoring zone -->
                        <Border Grid.Column="0" BorderBrush="#33579A" BorderThickness="1,3,1,1" Background="#0A1428" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="HOME" Foreground="#7EB4FF" FontSize="10" FontWeight="Black"/>
                                <TextBlock x:Name="HomeScoreDisplay" Grid.Row="1" Text="0" Foreground="White" FontSize="48" FontWeight="Black" FontFamily="Bahnschrift" Margin="0,4,0,0"/>
                                <Button x:Name="HomeGoalBtn" Grid.Row="3" Content="+6 GOAL" Style="{StaticResource ScoreButton}" Background="#2F63D1" BorderBrush="#4D7DE7"/>
                                <Button x:Name="HomeBehindBtn" Grid.Row="5" Content="+1 BEHIND" Style="{StaticResource ScoreButton}" FontSize="16" Background="#1A2636" BorderBrush="#3A4E66"/>
                            </Grid>
                        </Border>

                        <!-- AWAY scoring zone -->
                        <Border Grid.Column="2" BorderBrush="#8A3A3A" BorderThickness="1,3,1,1" Background="#1C0A0A" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="14"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="AWAY" Foreground="#FF9A9A" FontSize="10" FontWeight="Black"/>
                                <TextBlock x:Name="AwayScoreDisplay" Grid.Row="1" Text="0" Foreground="White" FontSize="48" FontWeight="Black" FontFamily="Bahnschrift" Margin="0,4,0,0"/>
                                <Button x:Name="AwayGoalBtn" Grid.Row="3" Content="+6 GOAL" Style="{StaticResource ScoreButton}" Background="#A63B3B" BorderBrush="#C56F6F"/>
                                <Button x:Name="AwayBehindBtn" Grid.Row="5" Content="+1 BEHIND" Style="{StaticResource ScoreButton}" FontSize="16" Background="#2A1A1A" BorderBrush="#5A3A3A"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- Clock controls — amber accent zone -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ClockStartBtn" Grid.Column="0" Content="▶ Start" Height="56" FontSize="20" FontWeight="Black"
                                Style="{StaticResource ScoreButton}" Background="#0D3018" BorderBrush="#1A6040"/>
                        <Button x:Name="ClockPauseBtn" Grid.Column="2" Content="⏸ Pause" Height="56" FontSize="11" FontWeight="Bold"
                                Style="{StaticResource ToolBtn}" Background="#21262D" BorderBrush="#D29922"/>
                        <Button x:Name="ClockResetBtn" Grid.Column="4" Content="↺ Reset" Height="56" FontSize="11" FontWeight="Bold"
                                Style="{StaticResource ToolBtn}" Background="#2A1416" BorderBrush="#6B3A3E"/>
                    </Grid>
                </Grid>

                <!-- RIGHT: Event log + Quarter -->
                <Border Grid.Column="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="2" Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Quarter selector -->
                        <TextBlock Grid.Row="0" Text="QUARTER" Style="{StaticResource SectionHead}"/>
                        <ComboBox x:Name="QuarterSelector" Grid.Row="1" Width="140" HorizontalAlignment="Left"/>

                        <!-- Event log -->
                        <TextBlock Grid.Row="3" Text="MATCH LOG" Style="{StaticResource SectionHead}"/>
                        <Border Grid.Row="4" Background="#161B22" BorderBrush="#21262D" BorderThickness="1" Padding="6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ListBox x:Name="EventLog" Background="Transparent" BorderThickness="0" Foreground="#E6EDF3" FontSize="12" FontFamily="Consolas">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="4,3"/>
                                            <Setter Property="BorderBrush" Value="#21262D"/>
                                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>
        </Grid>
    </Viewbox>
</UserControl>
