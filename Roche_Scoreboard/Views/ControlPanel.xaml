<UserControl x:Class="Roche_Scoreboard.Views.ControlPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#10131A">
    <UserControl.Resources>
        <!-- Modern dark palette -->
        <Color x:Key="PanelBg">#181C23</Color>
        <Color x:Key="PanelSurface">#232834</Color>
        <Color x:Key="PanelAccent">#3A8DFF</Color>
        <Color x:Key="PanelAccent2">#F5A623</Color>
        <Color x:Key="PanelText">#F3F6FA</Color>
        <Color x:Key="PanelTextMuted">#8B97A7</Color>
        <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBg}"/>
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="{StaticResource PanelSurface}"/>
        <SolidColorBrush x:Key="PanelAccentBrush" Color="{StaticResource PanelAccent}"/>
        <SolidColorBrush x:Key="PanelAccent2Brush" Color="{StaticResource PanelAccent2}"/>
        <SolidColorBrush x:Key="PanelTextBrush" Color="{StaticResource PanelText}"/>
        <SolidColorBrush x:Key="PanelTextMutedBrush" Color="{StaticResource PanelTextMuted}"/>
        <Style x:Key="ScoreButton" TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10" BorderBrush="Transparent" BorderThickness="2" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.93"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale" Storyboard.TargetProperty="ScaleX" From="0.96" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BdScale" Storyboard.TargetProperty="ScaleY" From="0.96" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <!-- Top: Persistent match strip -->
        <Border Background="#1B2230" Padding="24,12" VerticalAlignment="Top" Height="72" CornerRadius="0,0,12,12" Effect="{DynamicResource DropShadowEffect}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                    <Ellipse Width="36" Height="36" Fill="#2A3A5A"/>
                    <TextBlock x:Name="HomeTeamName" Text="Home" Foreground="White" FontWeight="Bold" FontSize="18" Margin="12,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="HomeScore" Text="0" Grid.Column="1" Foreground="White" FontWeight="Black" FontSize="32" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="Timer" Text="00:00" Grid.Column="2" Foreground="#F5A623" FontWeight="Black" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock x:Name="AwayScore" Text="0" Grid.Column="3" Foreground="White" FontWeight="Black" FontSize="32" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Column="4" VerticalAlignment="Center">
                    <TextBlock x:Name="AwayTeamName" Text="Away" Foreground="White" FontWeight="Bold" FontSize="18" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <Ellipse Width="36" Height="36" Fill="#5A2A2A"/>
                </StackPanel>
            </Grid>
        </Border>
        <!-- Main area: scoring and clock controls -->
        <Grid Margin="0,84,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Home scoring -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="32,0,16,0">
                <Button x:Name="HomeGoalBtn" Content="GOAL" Style="{StaticResource ScoreButton}" Background="#2A3A5A"/>
                <Button x:Name="HomeBehindBtn" Content="BEHIND" Style="{StaticResource ScoreButton}" Background="#3A4A6A"/>
            </StackPanel>
            <!-- Clock controls -->
            <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="0,0,0,0" HorizontalAlignment="Center">
                <Button x:Name="ClockStartBtn" Content="Start" Style="{StaticResource ScoreButton}" Background="#3A8DFF"/>
                <Button x:Name="ClockPauseBtn" Content="Pause" Style="{StaticResource ScoreButton}" Background="#232834"/>
                <Button x:Name="ClockResetBtn" Content="Reset" Style="{StaticResource ScoreButton}" Background="#232834"/>
                <ComboBox x:Name="QuarterSelector" Width="120" Margin="0,8,0,0"/>
            </StackPanel>
            <!-- Away scoring -->
            <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="16,0,32,0">
                <Button x:Name="AwayGoalBtn" Content="GOAL" Style="{StaticResource ScoreButton}" Background="#5A2A2A"/>
                <Button x:Name="AwayBehindBtn" Content="BEHIND" Style="{StaticResource ScoreButton}" Background="#6A3A3A"/>
            </StackPanel>
        </Grid>
        <!-- Event log -->
        <Border Background="#232834" CornerRadius="8" Margin="32,320,32,80" Padding="16,12" VerticalAlignment="Bottom" Height="180">
            <StackPanel>
                <TextBlock Text="Event Log" Foreground="#8B97A7" FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>
                <ListBox x:Name="EventLog" Background="Transparent" BorderThickness="0" Foreground="#F3F6FA" FontSize="14"/>
            </StackPanel>
        </Border>
        <!-- Collapsible secondary features -->
        <Expander Header="More" Background="#181C23" Foreground="#8B97A7" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Margin="32,0,32,16">
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Button Content="Display Settings" Margin="0,0,12,0"/>
                <Button Content="Statistics" Margin="0,0,12,0"/>
                <Button Content="Messages"/>
            </StackPanel>
        </Expander>
    </Grid>
</UserControl>
