<Window x:Class="Roche_Scoreboard.Views.UpdatePromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available"
        Width="560" Height="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <!-- Scoreboard-style: sharp edges, neon double-layer border, team-coloured
         accent stripes split home/away across the top. -->
    <Border Background="#0D1117" BorderBrush="#58A6FF" BorderThickness="2" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Color="#58A6FF" Opacity="0.45"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- Top accent stripe -->
                <RowDefinition Height="Auto"/>   <!-- Title bar -->
                <RowDefinition Height="Auto"/>   <!-- Version pills -->
                <RowDefinition Height="*"/>      <!-- Release notes -->
                <RowDefinition Height="Auto"/>   <!-- Progress -->
                <RowDefinition Height="Auto"/>   <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Inner neon stripe -->
            <Border Grid.Row="0" Height="3">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#1F6FEB" Offset="0.0"/>
                        <GradientStop Color="#58A6FF" Offset="0.5"/>
                        <GradientStop Color="#3FB950" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Title bar: icon + label + version chip -->
            <Grid Grid.Row="1" Margin="24,18,24,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Sharp neon icon badge -->
                <Border Grid.Column="0" Width="48" Height="48" Background="#0D1117"
                        BorderBrush="#58A6FF" BorderThickness="2" VerticalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#58A6FF" Opacity="0.7"/>
                    </Border.Effect>
                    <TextBlock Text="&#x2191;" FontSize="26" FontWeight="Black" FontFamily="Bahnschrift"
                               Foreground="#58A6FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="14,0,0,0">
                    <TextBlock Text="UPDATE AVAILABLE" FontSize="22" FontWeight="Black" FontFamily="Bahnschrift" Foreground="White">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#58A6FF" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="A NEW BUILD IS READY TO INSTALL" FontSize="11" FontWeight="Bold" FontFamily="Bahnschrift"
                               Foreground="#8B949E" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Live status pill -->
                <Border Grid.Column="2" VerticalAlignment="Center" Background="#0D1117"
                        BorderBrush="#3FB950" BorderThickness="1.5" Padding="8,3">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#3FB950" Opacity="0.6"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Fill="#3FB950" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="LIVE" FontSize="10" FontWeight="Black" FontFamily="Bahnschrift" Foreground="#3FB950" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Version comparison block -->
            <Grid Grid.Row="2" Margin="24,12,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Current version chip -->
                <Border Grid.Column="0" Background="#0D1117" BorderBrush="#484F58" BorderThickness="1.5" Padding="10,6">
                    <StackPanel>
                        <TextBlock Text="INSTALLED" FontSize="10" FontWeight="Black" FontFamily="Bahnschrift" Foreground="#8B949E"/>
                        <TextBlock x:Name="CurrentVersionText" Text="1.0.0" FontSize="20" FontWeight="Black" FontFamily="Bahnschrift" Foreground="#E6EDF3" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Arrow -->
                <TextBlock Grid.Column="1" Text="&#x2192;" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift"
                           Foreground="#58A6FF" Margin="14,0,14,0" VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#58A6FF" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>

                <!-- New version chip -->
                <Border Grid.Column="2" Background="#0D1117" BorderBrush="#3FB950" BorderThickness="2" Padding="10,6">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="#3FB950" Opacity="0.55"/>
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock Text="LATEST" FontSize="10" FontWeight="Black" FontFamily="Bahnschrift" Foreground="#3FB950"/>
                        <TextBlock x:Name="NewVersionText" Text="1.1.0" FontSize="20" FontWeight="Black" FontFamily="Bahnschrift" Foreground="White" Margin="0,2,0,0">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="6" ShadowDepth="0" Color="#3FB950" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Release notes panel -->
            <Border Grid.Row="3" Margin="24,16,24,0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="1.5" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <!-- Section header bar -->
                    <Border Grid.Row="0" Background="#161B22" BorderBrush="#21262D" BorderThickness="0,0,0,1" Padding="10,5">
                        <TextBlock Text="WHAT'S NEW" FontSize="10" FontWeight="Black" FontFamily="Bahnschrift" Foreground="#58A6FF"/>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,8">
                        <TextBlock x:Name="ReleaseNotesText" Text="" Foreground="#C9D1D9" FontSize="12"
                                   FontFamily="Bahnschrift" TextWrapping="Wrap" LineHeight="18"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Progress bar (hidden until downloading) -->
            <Grid Grid.Row="4" Margin="24,12,24,0">
                <Border x:Name="ProgressPanel" Visibility="Collapsed">
                    <StackPanel>
                        <Border Background="#161B22" BorderBrush="#21262D" BorderThickness="1" Height="10" ClipToBounds="True">
                            <Border x:Name="ProgressFill" Background="#58A6FF"
                                    HorizontalAlignment="Left" Width="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#58A6FF" Opacity="0.7"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                        <TextBlock x:Name="ProgressText" Text="Downloading..." Foreground="#58A6FF"
                                   FontSize="11" FontWeight="Black" FontFamily="Bahnschrift"
                                   Margin="0,5,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Buttons \u2014 sharp neon edges -->
            <Grid Grid.Row="5" Margin="24,16,24,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="SkipButton" Grid.Column="0" Content="SKIP FOR NOW" Height="46"
                        FontSize="13" FontWeight="Black" FontFamily="Bahnschrift" Cursor="Hand"
                        Click="Skip_Click"
                        Background="#0D1117" Foreground="#8B949E" BorderBrush="#484F58" BorderThickness="1.5">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Cursor="Hand">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#8B949E"/>
                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="UpdateButton" Grid.Column="2" Content="UPDATE NOW" Height="46"
                        FontSize="13" FontWeight="Black" FontFamily="Bahnschrift" Cursor="Hand"
                        Click="Update_Click"
                        Background="#0D1117" Foreground="#3FB950" BorderBrush="#3FB950" BorderThickness="2">
                    <Button.Effect>
                        <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#3FB950" Opacity="0.55"/>
                    </Button.Effect>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Cursor="Hand">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0F2A14"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>
