<UserControl x:Class="Roche_Scoreboard.Views.CricketControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0B1120">

    <UserControl.Resources>
        <Color x:Key="Surface1">#111827</Color>
        <Color x:Key="Surface2">#1E293B</Color>
        <Color x:Key="Surface3">#334155</Color>
        <Color x:Key="Accent">#818CF8</Color>

        <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
        <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#475569"/>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
        </Style>
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
        <Style x:Key="RunBtn" TargetType="Button">
            <Setter Property="Height" Value="50"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="8" Padding="10,0" Background="{StaticResource Surface2Brush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface3Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PanelTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="10,10,0,0" Padding="{TemplateBinding Padding}" Margin="0,0,2,0">
                            <ContentPresenter x:Name="Cp" ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface1Brush}"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- STATUS BAR -->
        <Border Grid.Row="0" Padding="16,10" Background="#111827">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🏏" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="InningsLabel" Text="1st Innings" Foreground="White" FontSize="16" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="HeaderScore" Text="0/0 (0)" Foreground="White" FontSize="18" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1" Margin="12,8,12,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="340"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="360" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: SCORING -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- BATTER BARS -->
                    <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="BATTING" Style="{StaticResource SectionHead}"/>
                            <!-- Top batter bar -->
                            <Border x:Name="StrikerBar" CornerRadius="10" Padding="12,10" Margin="0,0,0,4" Background="#1A1D4ED8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TopBatterIndicator" Text="▶" Foreground="#818CF8" FontSize="14" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="StrikerName" Text="Striker" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="StrikerStats" Text="0 (0)  SR 0.0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="StrikerRuns" Text="0" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="3" Content="⋯" Click="StrikerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Batter" Click="ChangeStriker_Click"/>
                                                <MenuItem Header="Swap Strike" Click="SwapStrike_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Bottom batter bar -->
                            <Border x:Name="NonStrikerBar" CornerRadius="10" Padding="12,10" Margin="0,0,0,0" Background="#1A1D4ED8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="BottomBatterIndicator" Text="  " Foreground="#818CF8" FontSize="14" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="NonStrikerName" Text="Non-Striker" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="NonStrikerStats" Text="0 (0)  SR 0.0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="NonStrikerRunsText" Text="0" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="3" Content="⋯" Click="NonStrikerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Batter" Click="ChangeNonStriker_Click"/>
                                                <MenuItem Header="Swap Strike" Click="SwapStrike_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- BOWLER BAR -->
                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="BOWLING" Style="{StaticResource SectionHead}"/>
                            <Border x:Name="BowlerBar" CornerRadius="10" Padding="12,10" Background="#1A15803D">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="BowlerName" Text="Bowler" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="BowlerStats" Text="0-0 (0)  Econ 0.00" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" x:Name="BowlerFigures" Text="0-0" Foreground="White" FontSize="20" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="⋯" Click="BowlerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Bowler" Click="ChangeBowlerMenu_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="OverDisplay" Text="This over: " Foreground="{StaticResource TextMutedBrush}" FontSize="11" Margin="4,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- SCORING GRID -->
                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="SCORING" Style="{StaticResource SectionHead}"/>
                            <UniformGrid Columns="4" Margin="0,0,0,6">
                                <Button Content="•" Click="Dot_Click" Style="{StaticResource RunBtn}" ToolTip="Dot ball">
                                    <Button.Background><SolidColorBrush Color="{StaticResource Surface3}"/></Button.Background>
                                </Button>
                                <Button Content="1" Click="Run1_Click" Style="{StaticResource RunBtn}" Margin="4,0" ToolTip="1 run">
                                    <Button.Background><SolidColorBrush Color="#1E40AF"/></Button.Background>
                                </Button>
                                <Button Content="2" Click="Run2_Click" Style="{StaticResource RunBtn}" Margin="0,0,4,0" ToolTip="2 runs">
                                    <Button.Background><SolidColorBrush Color="#1E40AF"/></Button.Background>
                                </Button>
                                <Button Content="3" Click="Run3_Click" Style="{StaticResource RunBtn}" ToolTip="3 runs">
                                    <Button.Background><SolidColorBrush Color="#1E40AF"/></Button.Background>
                                </Button>
                            </UniformGrid>
                            <UniformGrid Columns="4">
                                <Button Content="4" Click="Four_Click" Style="{StaticResource RunBtn}" ToolTip="Boundary four">
                                    <Button.Background><SolidColorBrush Color="#15803D"/></Button.Background>
                                </Button>
                                <Button Content="5" Click="Run5_Click" Style="{StaticResource RunBtn}" Margin="4,0" ToolTip="5 runs">
                                    <Button.Background><SolidColorBrush Color="#1E40AF"/></Button.Background>
                                </Button>
                                <Button Content="6" Click="Six_Click" Style="{StaticResource RunBtn}" Margin="0,0,4,0" ToolTip="Maximum six">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#9333EA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button Content="W" Click="Wicket_Click" Style="{StaticResource RunBtn}" ToolTip="Wicket">
                                    <Button.Background><SolidColorBrush Color="#DC2626"/></Button.Background>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- EXTRAS & ACTIONS -->
                    <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,6">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="EXTRAS" Style="{StaticResource SectionHead}"/>
                                <UniformGrid Columns="4">
                                    <Button Content="Wide" Click="Wide_Click" Style="{StaticResource ToolBtn}" ToolTip="Wide delivery"/>
                                    <Button Content="No Ball" Click="NoBall_Click" Style="{StaticResource ToolBtn}" ToolTip="No ball"/>
                                    <Button Content="Bye" Click="Bye_Click" Style="{StaticResource ToolBtn}" ToolTip="Bye runs"/>
                                    <Button Content="Leg Bye" Click="LegBye_Click" Style="{StaticResource ToolBtn}" ToolTip="Leg bye"/>
                                </UniformGrid>
                            </StackPanel>

                            <!-- Extras popup overlay -->
                            <Border x:Name="ExtrasPopup" Visibility="Collapsed" Panel.ZIndex="10"
                                    CornerRadius="14" Background="#111827" BorderBrush="{StaticResource AccentBrush}" BorderThickness="2"
                                    Padding="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock x:Name="ExtrasPopupTitle" Text="WIDE" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <Button Content="✕" HorizontalAlignment="Right" Click="ExtrasPopupClose_Click" Style="{StaticResource MenuBtn}"/>
                                    </Grid>
                                    <TextBlock Text="Additional runs:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="5" Margin="0,0,0,6">
                                        <Button Content="0" Tag="0" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+1" Tag="1" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+2" Tag="2" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+3" Tag="3" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+4" Tag="4" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                    </UniformGrid>
                                    <!-- No-ball sub-extras (only shown for No Ball) -->
                                    <StackPanel x:Name="NoBallSubExtrasPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                        <TextBlock Text="Or no-ball with extra type:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <UniformGrid Columns="3" Margin="0,0,0,4">
                                            <Button Content="NB + Wide" Tag="nbwide" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                            <Button Content="NB + Bye" Tag="nbbye" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                            <Button Content="NB + Leg Bye" Tag="nblb" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                        </UniformGrid>
                                        <!-- Sub-extra additional runs (shown after selecting sub-type) -->
                                        <StackPanel x:Name="NoBallSubRunsPanel" Visibility="Collapsed">
                                            <TextBlock x:Name="NoBallSubRunsLabel" Text="NB + Wide — additional runs:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,2,0,4"/>
                                            <UniformGrid Columns="5">
                                                <Button Content="0" Tag="0" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+1" Tag="1" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+2" Tag="2" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+3" Tag="3" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+4" Tag="4" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock x:Name="ExtrasHintText" Text="Total: 1 + additional runs" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <UniformGrid Grid.Row="4" Columns="2" Margin="0,0,0,6">
                        <Button Content="↩ Undo" Click="Undo_Click" Style="{StaticResource ToolBtn}" ToolTip="Undo last delivery"/>
                        <Button Content="End Innings" Click="EndInnings_Click" Style="{StaticResource ToolBtn}" ToolTip="End innings"/>
                    </UniformGrid>
                </Grid>
            </ScrollViewer>

            <!-- RIGHT: TABS -->
            <TabControl Grid.Column="2" Background="Transparent" BorderThickness="0" Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource PanelTab}"/>
                </TabControl.Resources>

                <TabItem Header="Display">
                    <Border Style="{StaticResource Card}" Margin="0,4,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="PRESENTATION" Style="{StaticResource SectionHead}"/>
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Content="Scorebug" Click="ShowScorebug_Click" Style="{StaticResource ToolBtn}"/>
                                    <Button Content="Window" Click="ShowWindow_Click" Style="{StaticResource ToolBtn}"/>
                                    <Button Content="Batting Card" Click="ShowBattingSummary_Click" Style="{StaticResource ToolBtn}" ToolTip="Show batting scorecard"/>
                                    <Button Content="Bowling Card" Click="ShowBowlingSummary_Click" Style="{StaticResource ToolBtn}" ToolTip="Show bowling scorecard"/>
                                </UniformGrid>
                                <Border Height="1" Background="{StaticResource Surface2Brush}" Margin="0,10,0,12"/>
                                <TextBlock Text="OVERLAYS" Style="{StaticResource SectionHead}"/>
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Content="Stats" Click="OverlayStats_Click" Style="{StaticResource ToolBtn}" ToolTip="Show stats bar on scorebug"/>
                                    <Button Content="Partnership" Click="OverlayPartnership_Click" Style="{StaticResource ToolBtn}" ToolTip="Show partnership overlay"/>
                                    <Button Content="Extras" Click="OverlayExtras_Click" Style="{StaticResource ToolBtn}" ToolTip="Show extras breakdown overlay"/>
                                    <Button Content="This Over" Click="OverlayThisOver_Click" Style="{StaticResource ToolBtn}" ToolTip="Show this over ball tracker"/>
                                </UniformGrid>
                                <Border Height="1" Background="{StaticResource Surface2Brush}" Margin="0,10,0,12"/>
                                <TextBlock Text="MESSAGES" Style="{StaticResource SectionHead}"/>
                                <ListBox x:Name="MessageList" Background="Transparent" Foreground="White" FontSize="11" BorderThickness="0" MaxHeight="80"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="NewMessageBox" FontSize="11" VerticalContentAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="+" Width="26" Height="24" FontSize="11" FontWeight="Bold" Margin="0,0,3,0" Click="AddMessage_Click" Style="{StaticResource ToolBtn}"/>
                                    <Button Grid.Column="2" Content="−" Width="26" Height="24" FontSize="11" FontWeight="Bold" Click="RemoveMessage_Click" Style="{StaticResource ToolBtn}"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>

                <TabItem Header="Log">
                    <Border Style="{StaticResource Card}" Margin="0,4,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="DELIVERY LOG" Style="{StaticResource SectionHead}"/>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="EventLog"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </TabItem>

                <TabItem Header="Settings">
                    <Border Style="{StaticResource Card}" Margin="0,4,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="BOWLER SELECTION" Style="{StaticResource SectionHead}"/>
                                <ListBox x:Name="BowlerList" Background="Transparent" Foreground="White" FontSize="12" BorderThickness="0" MaxHeight="200" SelectionChanged="BowlerList_SelectionChanged"/>
                                <Border Height="1" Background="{StaticResource Surface2Brush}" Margin="0,12"/>
                                <Button Content="Reset Match" Height="32" FontSize="12" FontWeight="Bold" Foreground="#CF6679" Click="ResetMatch_Click" Style="{StaticResource ToolBtn}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- BATTER SELECTION OVERLAY -->
        <Border x:Name="BatterSelectionOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0B1120" Grid.RowSpan="2">
            <Border MaxWidth="400" MaxHeight="500" Background="#111827" CornerRadius="16" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="BatterSelectionTitle" Text="SELECT NEW BATTER" Foreground="White" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Choose the next batter to come in" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="2" x:Name="BatterSelectionList" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" MinHeight="120"/>
                    <Button Grid.Row="3" Content="Confirm" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmBatterSelection_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10" Background="{StaticResource AccentBrush}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- BOWLER SELECTION OVERLAY -->
        <Border x:Name="BowlerSelectionOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0B1120" Grid.RowSpan="2">
            <Border MaxWidth="400" MaxHeight="500" Background="#111827" CornerRadius="16" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SELECT BOWLER" Foreground="White" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" x:Name="BowlerSelectionHint" Text="End of over — choose the next bowler" Foreground="{StaticResource TextMutedBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="2" x:Name="BowlerSelectionList" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" MinHeight="120"/>
                    <Button Grid.Row="3" Content="Confirm" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmBowlerSelection_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10" Background="{StaticResource AccentBrush}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- WICKET DETAILS OVERLAY -->
        <Border x:Name="WicketDetailsOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0B1120" Grid.RowSpan="2">
            <Border MaxWidth="420" MaxHeight="600" Background="#111827" CornerRadius="16" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#DC2626" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="WICKET DETAILS" Foreground="#DC2626" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" x:Name="WicketBatsmanLabel" Text="Batter: J. Smith" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Text="How out:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <WrapPanel Grid.Row="3" Margin="0,0,0,10">
                        <Button Content="Bowled" Tag="Bowled" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Caught" Tag="Caught" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="C &amp; B" Tag="CaughtAndBowled" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="LBW" Tag="LBW" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Run Out" Tag="RunOut" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Stumped" Tag="Stumped" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Hit Wicket" Tag="HitWicket" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Other" Tag="Other" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                    </WrapPanel>

                    <StackPanel Grid.Row="4" x:Name="WicketFielderPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Fielder:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ListBox x:Name="WicketFielderList" Background="Transparent" Foreground="White" FontSize="13" BorderThickness="0" MaxHeight="120"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" x:Name="WicketBowlerPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Bowler:" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="WicketBowlerAutoLabel" Text="" Foreground="#4ADE80" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                    </StackPanel>

                    <Button Grid.Row="6" Content="Confirm Wicket" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmWicket_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" CornerRadius="10" Background="#DC2626">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- OVERLAY QUEUE INDICATOR (enhanced) -->
        <Border x:Name="OverlayQueueBadge" Visibility="Collapsed" Panel.ZIndex="60"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,0" Grid.Row="0"
                CornerRadius="12" Padding="10,4" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#818CF8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏳" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="OverlayQueueText" Text="0 queued" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
