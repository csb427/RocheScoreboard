<UserControl x:Class="Roche_Scoreboard.Views.CricketControlPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D1117">

    <UserControl.Resources>
        <!-- ═══════════════════════════════════ -->
        <!-- COLOUR SYSTEM — broadcast console   -->
        <!-- ═══════════════════════════════════ -->
        <SolidColorBrush x:Key="ShellBrush" Color="#0D1117"/>
        <SolidColorBrush x:Key="RegionBrush" Color="#161B22"/>
        <SolidColorBrush x:Key="RegionAltBrush" Color="#1C2128"/>
        <SolidColorBrush x:Key="RegionEdgeBrush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextStrongBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextMidBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="#484F58"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#818CF8"/>
        <SolidColorBrush x:Key="LiveBrush" Color="#3FB950"/>
        <SolidColorBrush x:Key="WarnBrush" Color="#D29922"/>

        <!-- Legacy keys (referenced by overlays) -->
        <SolidColorBrush x:Key="Surface1Brush" Color="#161B22"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="#21262D"/>
        <SolidColorBrush x:Key="Surface3Brush" Color="#30363D"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E6EDF3"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8B949E"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#484F58"/>

        <!-- ── Section heading — uppercase, tracked ── -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <!-- ── Card — region panel ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource RegionBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RegionEdgeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14"/>
        </Style>

        <!-- ── Primary command button — scoring, with tactile depress and hover lift ── -->
        <Style x:Key="RunBtn" TargetType="Button">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5" Opacity="1">
                            <Border.RenderTransform><ScaleTransform x:Name="Sc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1.02" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleX" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Sc" Storyboard.TargetProperty="ScaleY" From="0.93" To="1.02" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0.65" To="1" Duration="0:0:0.25">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tool button — compact, hover glow, tactile press ── -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextStrongBrush}"/>
            <Setter Property="Background" Value="#21262D"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                RenderTransformOrigin="0.5,0.5" Opacity="1">
                            <Border.RenderTransform><ScaleTransform x:Name="TbSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#484F58"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleX" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="TbSc" Storyboard.TargetProperty="ScaleY" From="0.94" To="1.03" Duration="0:0:0.16">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.25" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity" From="0.7" To="1" Duration="0:0:0.22">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Menu/overflow button ── -->
        <Style x:Key="MenuBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="Transparent"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="MbSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#30363D"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MbSc" Storyboard.TargetProperty="ScaleX" To="1.1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="MbSc" Storyboard.TargetProperty="ScaleY" To="1.1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="MbSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="MbSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Tab strip — accent underline with animated hover ── -->
        <Style x:Key="PanelTab" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,3" Padding="{TemplateBinding Padding}" Margin="0,0,2,0"
                                RenderTransformOrigin="0.5,1">
                            <Border.RenderTransform><ScaleTransform x:Name="TabSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter x:Name="Cp" ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#161B22"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1C2128"/>
                                <Setter TargetName="Cp" Property="TextBlock.Foreground" Value="{StaticResource TextStrongBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabSc" Storyboard.TargetProperty="ScaleY" To="1.04" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TabSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.18">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Master Viewbox: at the natural design size (1500×900) the layout is
         identical to before. If the host window is smaller, the entire
         control panel scales DOWN proportionally so it always fits. -->
    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Grid Width="1500" Height="900" Background="{StaticResource ShellBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- ═══ PERSISTENT MATCH STRIP — always visible, dense, functional ═══ -->
        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#21262D" BorderThickness="0,0,0,2" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status badge — green/amber -->
                <Border Grid.Column="0" BorderBrush="#244A34" BorderThickness="1.5" Background="#0D2818" Padding="10,4">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#3FB950" Margin="0,0,6,0"/>
                        <TextBlock Text="LIVE" Foreground="#3FB950" FontSize="11" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <!-- Innings label — dominant -->
                <TextBlock Grid.Column="2" x:Name="InningsLabel" Text="1st Innings" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center"/>

                <!-- Over count -->
                <Border Grid.Column="4" BorderBrush="#30363D" BorderThickness="1" Background="#161B22" Padding="10,4">
                    <TextBlock x:Name="HeaderOvers" Text="" Foreground="{StaticResource TextMidBrush}" FontSize="10" FontWeight="Bold"/>
                </Border>

                <!-- Score readout -->
                <TextBlock Grid.Column="6" x:Name="HeaderScore" Text="0/0" Foreground="White" FontSize="28" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══ MAIN CONTENT — tabbed command surface ═══ -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0" TabStripPlacement="Top">
            <TabControl.Resources>
                <Style TargetType="TabItem" BasedOn="{StaticResource PanelTab}"/>
            </TabControl.Resources>

            <!-- ══════════════════════════════════════════ -->
            <!-- TAB 1: SCORING — the heart                -->
            <!-- ══════════════════════════════════════════ -->
            <TabItem Header="SCORING">
                <Border Background="{StaticResource RegionBrush}" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0" Padding="12,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="290" MinWidth="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: Scoring controls — command deck -->
                        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                    <!-- BATTING — team-coloured accent zone -->
                    <Border Grid.Row="0" x:Name="BattingZone" BorderBrush="#4D3D8F" BorderThickness="1,3,1,1" Background="#0D0A28" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="BATTING" Foreground="#A78BFA" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                            <!-- Top batter bar -->
                            <Border x:Name="StrikerBar" Background="#1C2128" BorderBrush="#30363D" BorderThickness="1" Padding="12,10" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="TopBatterIndicator" Text="▶" Foreground="#818CF8" FontSize="14" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="StrikerName" Text="Striker" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="StrikerStats" Text="0 (0)  SR 0.0" Foreground="{StaticResource TextMidBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="StrikerRuns" Text="0" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="3" Content="⋯" Click="StrikerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Batter" Click="ChangeStriker_Click"/>
                                                <MenuItem Header="Swap Strike" Click="SwapStrike_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                            <!-- Bottom batter bar -->
                            <Border x:Name="NonStrikerBar" Background="#1C2128" BorderBrush="#30363D" BorderThickness="1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="BottomBatterIndicator" Text="  " Foreground="#818CF8" FontSize="14" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock x:Name="NonStrikerName" Text="Non-Striker" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="NonStrikerStats" Text="0 (0)  SR 0.0" Foreground="{StaticResource TextMidBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" x:Name="NonStrikerRunsText" Text="0" Foreground="White" FontSize="24" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="3" Content="⋯" Click="NonStrikerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Batter" Click="ChangeNonStriker_Click"/>
                                                <MenuItem Header="Swap Strike" Click="SwapStrike_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- BOWLING — green accent zone -->
                    <Border Grid.Row="1" x:Name="BowlingZone" BorderBrush="#1A6040" BorderThickness="1,3,1,1" Background="#0D1E14" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="BOWLING" Foreground="#4ADE80" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                            <Border x:Name="BowlerBar" Background="#1C2128" BorderBrush="#30363D" BorderThickness="1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="BowlerName" Text="Bowler" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock x:Name="BowlerStats" Text="0-0 (0)  Econ 0.00" Foreground="{StaticResource TextMidBrush}" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" x:Name="BowlerFigures" Text="0-0" Foreground="White" FontSize="20" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Column="2" Content="⋯" Click="BowlerMenu_Click" Style="{StaticResource MenuBtn}" ToolTip="Options">
                                        <Button.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Change Bowler" Click="ChangeBowlerMenu_Click"/>
                                            </ContextMenu>
                                        </Button.ContextMenu>
                                    </Button>
                                </Grid>
                            </Border>
                            <TextBlock x:Name="OverDisplay" Text="This over: " Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="4,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- SCORING GRID — run buttons with gradient accents -->
                    <Border Grid.Row="2" Background="{StaticResource RegionAltBrush}" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="1" Padding="12" Margin="0,0,0,8">
                        <StackPanel>
                            <TextBlock Text="SCORING" Style="{StaticResource SectionHead}"/>
                            <UniformGrid Columns="4" Margin="0,0,0,6">
                                <Button Content="•" Click="Dot_Click" Style="{StaticResource RunBtn}" ToolTip="Dot ball" Background="#30363D" BorderBrush="#484F58"/>
                                <Button Content="1" Click="Run1_Click" Style="{StaticResource RunBtn}" Margin="4,0" ToolTip="1 run" Background="#1E40AF" BorderBrush="#3B6AE0"/>
                                <Button Content="2" Click="Run2_Click" Style="{StaticResource RunBtn}" Margin="0,0,4,0" ToolTip="2 runs" Background="#1E40AF" BorderBrush="#3B6AE0"/>
                                <Button Content="3" Click="Run3_Click" Style="{StaticResource RunBtn}" ToolTip="3 runs" Background="#1E40AF" BorderBrush="#3B6AE0"/>
                            </UniformGrid>
                            <UniformGrid Columns="4">
                                <Button Content="4" Click="Four_Click" Style="{StaticResource RunBtn}" ToolTip="Boundary four" BorderBrush="#22C55E">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#15803D" Offset="0"/>
                                            <GradientStop Color="#166534" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button Content="5" Click="Run5_Click" Style="{StaticResource RunBtn}" Margin="4,0" ToolTip="5 runs" Background="#1E40AF" BorderBrush="#3B6AE0"/>
                                <Button Content="6" Click="Six_Click" Style="{StaticResource RunBtn}" Margin="0,0,4,0" ToolTip="Maximum six" BorderBrush="#A855F7">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#7C3AED" Offset="0"/>
                                            <GradientStop Color="#9333EA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                                <Button Content="W" Click="Wicket_Click" Style="{StaticResource RunBtn}" ToolTip="Wicket" BorderBrush="#F87171">
                                    <Button.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#DC2626" Offset="0"/>
                                            <GradientStop Color="#B91C1C" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Button.Background>
                                </Button>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <!-- EXTRAS — amber accent zone -->
                    <Border Grid.Row="3" Background="#1E1A00" BorderBrush="#D29922" BorderThickness="1,2,1,1" Padding="12" Margin="0,0,0,0">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="EXTRAS" Foreground="#D29922" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                                <UniformGrid Columns="4">
                                    <Button Content="Wide" Click="Wide_Click" Style="{StaticResource ToolBtn}" ToolTip="Wide delivery" Background="#2A2000" BorderBrush="#9A7316"/>
                                    <Button Content="No Ball" Click="NoBall_Click" Style="{StaticResource ToolBtn}" ToolTip="No ball" Background="#2A2000" BorderBrush="#9A7316"/>
                                    <Button Content="Bye" Click="Bye_Click" Style="{StaticResource ToolBtn}" ToolTip="Bye runs" Background="#2A2000" BorderBrush="#9A7316"/>
                                    <Button Content="Leg Bye" Click="LegBye_Click" Style="{StaticResource ToolBtn}" ToolTip="Leg bye" Background="#2A2000" BorderBrush="#9A7316"/>
                                </UniformGrid>
                            </StackPanel>

                            <!-- Extras popup overlay -->
                            <Border x:Name="ExtrasPopup" Visibility="Collapsed" Panel.ZIndex="10"
                                    Background="#161B22" BorderBrush="#D29922" BorderThickness="2"
                                    Padding="16" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <TextBlock x:Name="ExtrasPopupTitle" Text="WIDE" Foreground="#D29922" FontSize="14" FontWeight="Black" VerticalAlignment="Center"/>
                                        <Button Content="✕" HorizontalAlignment="Right" Click="ExtrasPopupClose_Click" Style="{StaticResource MenuBtn}"/>
                                    </Grid>
                                    <TextBlock Text="Additional runs:" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="5" Margin="0,0,0,6">
                                        <Button Content="0" Tag="0" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+1" Tag="1" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+2" Tag="2" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+3" Tag="3" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Content="+4" Tag="4" Click="ExtrasRun_Click" Style="{StaticResource ToolBtn}"/>
                                    </UniformGrid>
                                    <StackPanel x:Name="NoBallSubExtrasPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                        <TextBlock Text="Or no-ball with extra type:" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,0,0,4"/>
                                        <UniformGrid Columns="3" Margin="0,0,0,4">
                                            <Button Content="NB + Wide" Tag="nbwide" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                            <Button Content="NB + Bye" Tag="nbbye" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                            <Button Content="NB + Leg Bye" Tag="nblb" Click="NoBallSubType_Click" Style="{StaticResource ToolBtn}"/>
                                        </UniformGrid>
                                        <StackPanel x:Name="NoBallSubRunsPanel" Visibility="Collapsed">
                                            <TextBlock x:Name="NoBallSubRunsLabel" Text="NB + Wide — additional runs:" Foreground="{StaticResource TextMidBrush}" FontSize="11" Margin="0,2,0,4"/>
                                            <UniformGrid Columns="5">
                                                <Button Content="0" Tag="0" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+1" Tag="1" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+2" Tag="2" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+3" Tag="3" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                                <Button Content="+4" Tag="4" Click="NoBallSubRun_Click" Style="{StaticResource ToolBtn}"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock x:Name="ExtrasHintText" Text="Total: 1 + additional runs" Foreground="{StaticResource TextDimBrush}" FontSize="10" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- UNDO / END INNINGS — danger row -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.5*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="↩ Undo" Height="42" Click="Undo_Click" Style="{StaticResource ToolBtn}" ToolTip="Undo last delivery" Background="#21262D" BorderBrush="#6B3A3E"/>
                        <Button Grid.Column="2" Content="End Innings" Height="42" Click="EndInnings_Click" Style="{StaticResource ToolBtn}" ToolTip="End innings" Background="#2A1416" BorderBrush="#6B3A3E" Foreground="#FF6B6B"/>
                    </Grid>

                    <!-- RESET — danger zone -->
                    <Button Grid.Row="7" Content="⟲  RESET MATCH" Height="42" FontSize="13" FontWeight="Black" Click="ResetMatch_Click"
                            Style="{StaticResource ToolBtn}" ToolTip="Reset the entire match and return to setup"
                            Background="#2A1416" BorderBrush="#6B3A3E" Foreground="#FF6B6B"/>
                                </Grid>
                        </ScrollViewer>

                        <!-- RIGHT: Delivery log — live feed style -->
                        <Border Grid.Column="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="2" Padding="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="DELIVERY LOG" Style="{StaticResource SectionHead}"/>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                    <StackPanel x:Name="EventLog"/>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ══════════════════════════════════════════ -->
            <!-- TAB 2: DISPLAY &amp; MESSAGES — cinematic  -->
            <!-- ══════════════════════════════════════════ -->
            <TabItem Header="DISPLAY &amp; OVERLAYS">
                <Border Background="#0A0E18" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0">
                    <Grid>
                        <!-- Ambient background glow -->
                        <Border Opacity="0.06" IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush Center="0.3,0.2" RadiusX="0.7" RadiusY="0.7">
                                    <GradientStop Color="#818CF8" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Vignette -->
                        <Border IsHitTestVisible="False">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#00000000" Offset="0.3"/>
                                    <GradientStop Color="#40000000" Offset="1.0"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>

                        <Grid Margin="20,16,20,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- LEFT: Presentation + Overlays -->
                            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel>
                                    <!-- PRESENTATION MODE heading -->
                                    <StackPanel HorizontalAlignment="Left" Margin="0,0,0,12">
                                        <TextBlock Text="PRESENTATION MODE" FontSize="14" FontWeight="Black" Foreground="#818CF8" Margin="0,0,0,2">
                                            <TextBlock.Effect>
                                                <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#818CF8" Opacity="0.3"/>
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock Text="Select the active display for the scoreboard window" FontSize="9" FontWeight="SemiBold" Foreground="#3A4A6A"/>
                                    </StackPanel>

                                    <!-- Presentation cards -->
                                    <UniformGrid Columns="4" Margin="0,0,0,6">
                                        <Border Cursor="Hand" Background="#0A1628" BorderBrush="#818CF8" BorderThickness="2" Margin="3" MouseLeftButtonUp="ShowScorebug_Click">
                                            <Grid MinHeight="80">
                                                <Border Opacity="0.12" IsHitTestVisible="False">
                                                    <Border.Background>
                                                        <RadialGradientBrush Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
                                                            <GradientStop Color="#818CF8" Offset="0"/>
                                                            <GradientStop Color="#00000000" Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Scorebug" Foreground="White" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Border Cursor="Hand" Background="#0A1628" BorderBrush="#30363D" BorderThickness="1" Margin="3" MouseLeftButtonUp="ShowBattingSummary_Click">
                                            <Grid MinHeight="80">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="🏏" FontSize="20" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Batting Card" Foreground="{StaticResource TextMidBrush}" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Border Cursor="Hand" Background="#0A1628" BorderBrush="#30363D" BorderThickness="1" Margin="3" MouseLeftButtonUp="ShowBowlingSummary_Click">
                                            <Grid MinHeight="80">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="🎯" FontSize="20" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Bowling Card" Foreground="{StaticResource TextMidBrush}" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Border Cursor="Hand" Background="#0A1628" BorderBrush="#30363D" BorderThickness="1" Margin="3" MouseLeftButtonUp="ShowWindow_Click">
                                            <Grid MinHeight="80">
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                    <TextBlock Text="🖥" FontSize="20" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="Window" Foreground="{StaticResource TextMidBrush}" FontSize="10" FontWeight="Black" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </UniformGrid>

                                    <!-- Divider -->
                                    <Border Height="1" Background="#21262D" Margin="0,10,0,12"/>

                                    <!-- OVERLAYS heading -->
                                    <StackPanel HorizontalAlignment="Left" Margin="0,0,0,10">
                                        <TextBlock Text="OVERLAYS" FontSize="12" FontWeight="Black" Foreground="#818CF8" Margin="0,0,0,1"/>
                                        <TextBlock Text="Trigger live overlays on the scorebug" FontSize="9" FontWeight="SemiBold" Foreground="#3A4A6A"/>
                                    </StackPanel>

                                    <!-- Game Analysis sub-section -->
                                    <TextBlock Text="GAME ANALYSIS" Style="{StaticResource SectionHead}" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <Button Content="📊 Stats Bar" Click="OverlayStats_Click" Style="{StaticResource ToolBtn}" ToolTip="Show stats bar on scorebug"/>
                                        <Button Content="🤝 Partnership" Click="OverlayPartnership_Click" Style="{StaticResource ToolBtn}" ToolTip="Show partnership overlay"/>
                                        <Button Content="📋 Extras" Click="OverlayExtras_Click" Style="{StaticResource ToolBtn}" ToolTip="Show extras breakdown overlay"/>
                                        <Button Content="⚾ This Over" Click="OverlayThisOver_Click" Style="{StaticResource ToolBtn}" ToolTip="Show this over ball tracker"/>
                                    </UniformGrid>

                                    <!-- Broadcast Bars sub-section -->
                                    <TextBlock Text="BROADCAST BARS" Style="{StaticResource SectionHead}" Margin="0,0,0,6"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <Button Content="🤝 Partnership Bar" Click="OverlayPartnershipBar_Click" Style="{StaticResource ToolBtn}" ToolTip="AFL-style partnership bar"/>
                                        <Button Content="📈 Run Rate" Click="OverlayRunRate_Click" Style="{StaticResource ToolBtn}" ToolTip="Current vs required run rate"/>
                                        <Button Content="🎯 Target/Chase" Click="OverlayTarget_Click" Style="{StaticResource ToolBtn}" ToolTip="Target, runs needed, balls remaining"/>
                                        <Button Content="⚡ Powerplay" Click="OverlayPowerplay_Click" Style="{StaticResource ToolBtn}" ToolTip="Powerplay overs indicator"/>
                                        <Button Content="📉 Last 5 Overs" Click="OverlayLast5_Click" Style="{StaticResource ToolBtn}" ToolTip="Runs in last 5 overs"/>
                                        <Button Content="🏜️ Drought" Click="OverlayDrought_Click" Style="{StaticResource ToolBtn}" ToolTip="Balls since last boundary"/>
                                    </UniformGrid>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- RIGHT: Messages -->
                            <Border Grid.Column="2" Background="#0D1117" BorderBrush="#21262D" BorderThickness="2" Padding="14">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="TICKER MESSAGES" Style="{StaticResource SectionHead}"/>
                                    <ListBox Grid.Row="1" x:Name="MessageList" Background="Transparent" Foreground="White" FontSize="11" BorderThickness="0"/>
                                    <Grid Grid.Row="2" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewMessageBox" FontSize="11" VerticalContentAlignment="Center" Margin="0,0,4,0" Background="#161B22" Foreground="White" BorderBrush="#30363D"/>
                                        <Button Grid.Column="1" Content="+" Width="26" Height="24" FontSize="11" FontWeight="Bold" Margin="0,0,3,0" Click="AddMessage_Click" Style="{StaticResource ToolBtn}"/>
                                        <Button Grid.Column="2" Content="−" Width="26" Height="24" FontSize="11" FontWeight="Bold" Click="RemoveMessage_Click" Style="{StaticResource ToolBtn}"/>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </TabItem>

            <!-- ══════════════════════════════════════════ -->
            <!-- TAB 3: SETTINGS — team management          -->
            <!-- ══════════════════════════════════════════ -->
            <TabItem Header="SETTINGS">
                <Border Background="{StaticResource RegionBrush}" BorderBrush="{StaticResource RegionEdgeBrush}" BorderThickness="0,1,0,0" Padding="20,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="BOWLER SELECTION" Style="{StaticResource SectionHead}"/>
                            <ListBox x:Name="BowlerList" Background="Transparent" Foreground="White" FontSize="12" BorderThickness="0" MaxHeight="200" SelectionChanged="BowlerList_SelectionChanged"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>
        </TabControl>

        <!-- ═══ BATTER SELECTION OVERLAY ═══ -->
        <Border x:Name="BatterSelectionOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0D1117" Grid.RowSpan="2">
            <Border MaxWidth="420" MaxHeight="500" Background="#161B22" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="BatterSelectionTitle" Text="SELECT NEW BATTER" Foreground="White" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" Text="Choose the next batter to come in" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="2" x:Name="BatterSelectionList" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" MinHeight="120"/>
                    <Button Grid.Row="3" Content="Confirm" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmBatterSelection_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{StaticResource AccentBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform><ScaleTransform x:Name="CfSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CfSc" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CfSc" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ BOWLER SELECTION OVERLAY ═══ -->
        <Border x:Name="BowlerSelectionOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0D1117" Grid.RowSpan="2">
            <Border MaxWidth="420" MaxHeight="500" Background="#161B22" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="{StaticResource AccentBrush}" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="SELECT BOWLER" Foreground="White" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" x:Name="BowlerSelectionHint" Text="End of over — choose the next bowler" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,0,0,10"/>
                    <ListBox Grid.Row="2" x:Name="BowlerSelectionList" Background="Transparent" Foreground="White" FontSize="14" BorderThickness="0" MinHeight="120"/>
                    <Button Grid.Row="3" Content="Confirm" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmBowlerSelection_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="{StaticResource AccentBrush}"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform><ScaleTransform x:Name="CfSc2" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="CfSc2" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="CfSc2" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- ═══ WICKET DETAILS OVERLAY ═══ -->
        <Border x:Name="WicketDetailsOverlay" Visibility="Collapsed" Panel.ZIndex="50"
                Background="#CC0D1117" Grid.RowSpan="2">
            <Border MaxWidth="420" MaxHeight="600" Background="#161B22" Padding="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                    BorderBrush="#DC2626" BorderThickness="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="WICKET DETAILS" Foreground="#DC2626" FontSize="16" FontWeight="Black" Margin="0,0,0,4"/>
                    <TextBlock Grid.Row="1" x:Name="WicketBatsmanLabel" Text="Batter: J. Smith" Foreground="White" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Text="How out:" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,4"/>
                    <WrapPanel Grid.Row="3" Margin="0,0,0,10">
                        <Button Content="Bowled" Tag="Bowled" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Caught" Tag="Caught" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="C &amp; B" Tag="CaughtAndBowled" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="LBW" Tag="LBW" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Run Out" Tag="RunOut" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Stumped" Tag="Stumped" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Hit Wicket" Tag="HitWicket" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                        <Button Content="Other" Tag="Other" Click="WicketType_Click" Style="{StaticResource ToolBtn}"/>
                    </WrapPanel>

                    <StackPanel Grid.Row="4" x:Name="WicketFielderPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Fielder:" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <ListBox x:Name="WicketFielderList" Background="Transparent" Foreground="White" FontSize="13" BorderThickness="0" MaxHeight="120"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" x:Name="WicketBowlerPanel" Visibility="Collapsed" Margin="0,0,0,8">
                        <TextBlock Text="Bowler:" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBlock x:Name="WicketBowlerAutoLabel" Text="" Foreground="#4ADE80" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                    </StackPanel>

                    <Button Grid.Row="6" Content="Confirm Wicket" Height="36" FontSize="13" FontWeight="Bold" Margin="0,10,0,0" Click="ConfirmWicket_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd" Background="#DC2626"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform><ScaleTransform x:Name="WkSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                </Trigger>
                                                <EventTrigger RoutedEvent="Button.Click">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="WkSc" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetName="WkSc" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.15">
                                                                <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </Border>
        </Border>

        <!-- OVERLAY QUEUE INDICATOR -->
        <Border x:Name="OverlayQueueBadge" Visibility="Collapsed" Panel.ZIndex="60"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,4,8,0" Grid.Row="0"
                Padding="10,4" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#6366F1" Offset="0"/>
                    <GradientStop Color="#818CF8" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⏳" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                <TextBlock x:Name="OverlayQueueText" Text="0 queued" Foreground="White" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        </Grid>
    </Viewbox>
</UserControl>
