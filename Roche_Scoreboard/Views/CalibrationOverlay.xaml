<UserControl x:Class="Roche_Scoreboard.Views.CalibrationOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid>
        <!-- Bright outer border so the operator can see the exact window edges -->
        <Border BorderBrush="#FFFF00FF" BorderThickness="2"/>

        <!-- Inner safe-area guide (~5% inset) -->
        <Border BorderBrush="#80FFFF00" BorderThickness="1" Margin="20"/>

        <!-- Crosshair: vertical -->
        <Rectangle Width="1" Fill="#80FF00FF" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
        <!-- Crosshair: horizontal -->
        <Rectangle Height="1" Fill="#80FF00FF" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>

        <!-- Corner L-markers -->
        <Path Data="M 0,30 L 0,0 L 30,0" Stroke="#FF00FFFF" StrokeThickness="3"
              HorizontalAlignment="Left" VerticalAlignment="Top"/>
        <Path Data="M 30,0 L 0,0 L 0,30" Stroke="#FF00FFFF" StrokeThickness="3"
              HorizontalAlignment="Right" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><ScaleTransform ScaleX="-1"/></Path.RenderTransform>
        </Path>
        <Path Data="M 0,30 L 0,0 L 30,0" Stroke="#FF00FFFF" StrokeThickness="3"
              HorizontalAlignment="Left" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><ScaleTransform ScaleY="-1"/></Path.RenderTransform>
        </Path>
        <Path Data="M 30,0 L 0,0 L 0,30" Stroke="#FF00FFFF" StrokeThickness="3"
              HorizontalAlignment="Right" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,0.5">
            <Path.RenderTransform><ScaleTransform ScaleX="-1" ScaleY="-1"/></Path.RenderTransform>
        </Path>

        <!-- Live size readout, top-left -->
        <Border Background="#C0000000" Padding="8,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="40,40,0,0">
            <TextBlock x:Name="SizeReadout"
                       Foreground="#FF00FF00"
                       FontFamily="Consolas"
                       FontSize="16"
                       FontWeight="Bold"
                       Text="0 x 0"/>
        </Border>

        <!-- Hint, bottom-center -->
        <Border Background="#C0000000" Padding="10,5" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40">
            <TextBlock Foreground="White" FontFamily="Consolas" FontSize="14"
                       Text="Calibration Mode  —  Ctrl+Shift+C to exit"/>
        </Border>
    </Grid>
</UserControl>
