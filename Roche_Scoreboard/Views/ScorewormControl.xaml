<UserControl x:Class="Roche_Scoreboard.Views.ScorewormControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Roche_Scoreboard.Views"
             mc:Ignorable="d"
             d:DesignHeight="193" d:DesignWidth="386"
             Width="386" Height="193">

    <!-- Fixed 386x193 layout authored 1:1. No Viewbox/scaling. -->
    <Grid>
        <Grid.Background>
            <LinearGradientBrush x:Name="WormBgGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0.0"/>
                <GradientStop Color="#0D1117" Offset="0.5"/>
                <GradientStop Color="#0D1117" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="16"/>   <!-- title -->
            <RowDefinition Height="22"/>   <!-- team headers -->
            <RowDefinition Height="*"/>    <!-- graph -->
            <RowDefinition Height="44"/>   <!-- score bar -->
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,1">
            <Border VerticalAlignment="Bottom" Height="1" IsHitTestVisible="False">
                <Border.Background>
                    <LinearGradientBrush x:Name="WormTitleAccent" StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#4488FF" Offset="0.0"/>
                        <GradientStop Color="#00000000" Offset="0.5"/>
                        <GradientStop Color="#FF6644" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
        </Border>
        <Grid Grid.Row="0" Margin="6,0">
            <TextBlock Text="SCORE WORM" Foreground="#F0C040"
                       FontSize="11" FontWeight="Black" FontFamily="Bahnschrift"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="WormTimeText" Text="1:26 PM" Foreground="#58A6FF"
                       FontSize="9" FontWeight="SemiBold"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- TEAM HEADERS -->
        <Grid Grid.Row="1" Margin="4,2,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="WormHomeTeamHeader" Grid.Column="0" Padding="3,1" BorderThickness="1" Height="20" Margin="0,0,2,0">
                <Border.Effect>
                    <DropShadowEffect x:Name="WormHomeGlow" BlurRadius="4" ShadowDepth="0" Color="#4488FF" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Ellipse x:Name="WormHomeLogoFallback" Width="14" Height="14" Fill="#22FFFFFF"/>
                        <Image x:Name="WormHomeLogoImage" Width="14" Height="14" Stretch="UniformToFill" Visibility="Collapsed">
                            <Image.Clip>
                                <EllipseGeometry Center="7,7" RadiusX="7" RadiusY="7"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                    <TextBlock x:Name="WormHomeTeamText" Grid.Column="1" Text="HOME"
                               FontSize="12" FontWeight="Black" FontFamily="Bahnschrift"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

            <Border x:Name="WormAwayTeamHeader" Grid.Column="1" Padding="3,1" BorderThickness="1" Height="20" Margin="2,0,0,0">
                <Border.Effect>
                    <DropShadowEffect x:Name="WormAwayGlow" BlurRadius="4" ShadowDepth="0" Color="#FF6644" Opacity="0.6"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="WormAwayTeamText" Grid.Column="0" Text="AWAY"
                               FontSize="12" FontWeight="Black" FontFamily="Bahnschrift"
                               VerticalAlignment="Center" TextAlignment="Right"
                               TextTrimming="CharacterEllipsis" Margin="0,0,4,0"/>
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <Ellipse x:Name="WormAwayLogoFallback" Width="14" Height="14" Fill="#22FFFFFF"/>
                        <Image x:Name="WormAwayLogoImage" Width="14" Height="14" Stretch="UniformToFill" Visibility="Collapsed">
                            <Image.Clip>
                                <EllipseGeometry Center="7,7" RadiusX="7" RadiusY="7"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- GRAPH -->
        <Grid Grid.Row="2" Margin="0,1,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="34"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="MARGIN" Foreground="#7088A0" FontSize="7"
                       FontWeight="Bold" FontFamily="Bahnschrift"
                       HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,1,0,0"/>
            <Canvas x:Name="YAxisCanvas" Grid.Column="0" ClipToBounds="False" Margin="0,9,0,0"/>
            <Grid Grid.Column="1" Margin="0,0,2,0">
                <Border ClipToBounds="True"
                        Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                    <Canvas x:Name="GraphCanvas" ClipToBounds="True"/>
                </Border>
                <!-- Dynamic margin badge: live point difference, font grows as gap widens -->
                <Border x:Name="WormMarginBadge"
                        VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="0,3,3,0"
                        CornerRadius="4" Padding="5,1" Background="#CC0D1117"
                        BorderBrush="#30363D" BorderThickness="1" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="WormMarginValue" Text="+0"
                                   FontWeight="Black" FontFamily="Bahnschrift"
                                   Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock x:Name="WormMarginLabel" Text=" HOME"
                                   FontWeight="Bold" FontFamily="Bahnschrift"
                                   Foreground="#A8B3BF" FontSize="9" VerticalAlignment="Center"
                                   Margin="3,2,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- BOTTOM SCORE BAR -->
        <local:PresentationScoreBar x:Name="ScoreBar" Grid.Row="3"/>
    </Grid>
</UserControl>
