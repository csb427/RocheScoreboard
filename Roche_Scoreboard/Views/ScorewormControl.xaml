<UserControl x:Class="Roche_Scoreboard.Views.ScorewormControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420" d:DesignWidth="707">

    <Viewbox Stretch="Fill">
        <Grid Width="707" Height="420">
            <Grid.Background>
                <LinearGradientBrush x:Name="WormBgGradient" StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A0E1F" Offset="0.0"/>
                    <GradientStop Color="#0F1628" Offset="0.5"/>
                    <GradientStop Color="#0A0E1F" Offset="1.0"/>
                </LinearGradientBrush>
            </Grid.Background>

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>   <!-- Title row -->
                <RowDefinition Height="*"/>    <!-- Graph area -->
                <RowDefinition Height="80"/>   <!-- Bottom bar -->
            </Grid.RowDefinitions>

            <!-- Title row -->
            <Grid Grid.Row="0">
                <!-- Time top-right -->
                <TextBlock x:Name="WormTimeText" Text="1:26 PM" Foreground="White" FontWeight="Black" FontSize="14"
                           HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,12,0"/>

                <!-- SCORE WORM title -->
                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="SCORE WORM" Foreground="White" FontSize="42" FontWeight="Black" FontStyle="Italic">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="8" ShadowDepth="3" Color="Black" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </Viewbox>

                <!-- Home team legend (left) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Rectangle x:Name="HomeLegendRect" Width="14" Height="14" RadiusX="3" RadiusY="3" Fill="#4488FF" Margin="0,0,6,0"/>
                    <TextBlock x:Name="HomeLegendText" Text="HOME" Foreground="#AAAAAA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Away team legend (right, before time) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,100,0">
                    <Rectangle x:Name="AwayLegendRect" Width="14" Height="14" RadiusX="3" RadiusY="3" Fill="#FF6644" Margin="0,0,6,0"/>
                    <TextBlock x:Name="AwayLegendText" Text="AWAY" Foreground="#AAAAAA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Graph area with Y-axis labels -->
            <Grid Grid.Row="1" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>  <!-- Y-axis labels -->
                    <ColumnDefinition Width="*"/>   <!-- Graph canvas -->
                </Grid.ColumnDefinitions>

                <!-- Y-axis label container -->
                <Canvas x:Name="YAxisCanvas" Grid.Column="0" ClipToBounds="False"/>

                <!-- Graph canvas -->
                <Border Grid.Column="1" CornerRadius="6" Margin="0,4,12,4" ClipToBounds="True">
                    <Border.Background>
                        <SolidColorBrush Color="#0D1220" Opacity="0.6"/>
                    </Border.Background>
                    <Canvas x:Name="GraphCanvas" ClipToBounds="True"/>
                </Border>
            </Grid>

            <!-- Persistent bottom bar (same structure as BreakScreenControl) -->
            <Border Grid.Row="2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#0A0A30" Offset="0.0"/>
                        <GradientStop Color="#1A1A6A" Offset="0.5"/>
                        <GradientStop Color="#0A0A30" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>

                    <Viewbox Grid.Column="0" Stretch="Uniform" StretchDirection="DownOnly" Margin="8,4">
                        <TextBlock x:Name="WormBarHomeAbbr" Text="XC" FontSize="40" FontWeight="Black">
                            <TextBlock.Foreground>
                                <SolidColorBrush x:Name="WormBarHomeAbbrBrush" Color="#FF6040"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Viewbox>

                    <Viewbox Grid.Column="1" Stretch="Uniform" StretchDirection="DownOnly" Margin="8,4">
                        <TextBlock x:Name="WormBarHomeScore" Text="8.5.53" Foreground="White" FontSize="40" FontWeight="Black"/>
                    </Viewbox>

                    <Border Grid.Column="2" CornerRadius="6" Margin="4,8">
                        <Border.Background>
                            <SolidColorBrush x:Name="WormBarTitleBg" Color="#2020AA"/>
                        </Border.Background>
                        <Viewbox Stretch="Uniform" StretchDirection="DownOnly" Margin="8,4">
                            <TextBlock x:Name="WormBarTitle" Text="3QT" Foreground="White" FontSize="40" FontWeight="Black"/>
                        </Viewbox>
                    </Border>

                    <Viewbox Grid.Column="3" Stretch="Uniform" StretchDirection="DownOnly" Margin="8,4">
                        <TextBlock x:Name="WormBarAwayScore" Text="6.12.48" Foreground="White" FontSize="40" FontWeight="Black"/>
                    </Viewbox>

                    <Viewbox Grid.Column="4" Stretch="Uniform" StretchDirection="DownOnly" Margin="8,4">
                        <TextBlock x:Name="WormBarAwayAbbr" Text="SKC" FontSize="40" FontWeight="Black">
                            <TextBlock.Foreground>
                                <SolidColorBrush x:Name="WormBarAwayAbbrBrush" Color="#40AA40"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </Viewbox>
                </Grid>
            </Border>
        </Grid>
    </Viewbox>
</UserControl>
