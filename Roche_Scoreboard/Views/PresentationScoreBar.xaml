<UserControl x:Class="Roche_Scoreboard.Views.PresentationScoreBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="44" d:DesignWidth="386"
             Height="44">

    <!-- Compact 386x44 score bar authored at 1:1 capture pixels.
         No Viewbox/scaling: every element is sized for native rendering. -->
    <Grid Background="#0D1117">

        <!-- 1px team-colour top accent -->
        <Border Height="1" VerticalAlignment="Top" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush x:Name="BarTopAccent" StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#4488FF" Offset="0.0"/>
                    <GradientStop Color="#30363D" Offset="0.5"/>
                    <GradientStop Color="#FF6644" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="44"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- HOME SECTION -->
            <Border Grid.Column="0" BorderThickness="0,0,1,0">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="HomeBgBrush" Color="#4488FF"/>
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush x:Name="HomeSectionBg" Color="#180D1117"/>
                </Border.Background>
                <Grid Margin="3,2,3,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <Grid Grid.Column="0" VerticalAlignment="Center">
                        <Ellipse x:Name="HomeLogoFallback" Width="22" Height="22" Fill="#22FFFFFF"/>
                        <Image x:Name="HomeLogoImage" Width="22" Height="22" Stretch="UniformToFill" Visibility="Collapsed">
                            <Image.Clip>
                                <EllipseGeometry Center="11,11" RadiusX="11" RadiusY="11"/>
                            </Image.Clip>
                        </Image>
                    </Grid>

                    <!-- Abbreviation -->
                    <TextBlock Grid.Column="1" x:Name="HomeAbbrText" Text="ADE"
                               FontSize="16" FontWeight="Black" FontFamily="Bahnschrift"
                               VerticalAlignment="Center" Margin="4,0,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush x:Name="HomeAbbrBrush" Color="#4488FF"/>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect x:Name="HomeAbbrGlow" Color="#4488FF" ShadowDepth="0" BlurRadius="4" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- G/B chips -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,4,0">
                        <Border CornerRadius="3" Padding="3,0" BorderThickness="1" Margin="0,0,2,0" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="HomeGoalsChipBg" Color="#30FFFFFF"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="HomeGoalsChipBorder" Color="#4488FF"/>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect x:Name="HomeGoalsChipGlow" Color="#4488FF" ShadowDepth="0" BlurRadius="3" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="HomeGoalsText" Text="16" FontSize="13" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="G" FontSize="8" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#B0B8C4" VerticalAlignment="Center" Margin="2,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="3" Padding="3,0" BorderThickness="1" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="HomeBehindsChipBg" Color="#14FFFFFF"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="HomeBehindsChipBorder" Color="#4488FF"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="HomeBehindsText" Text="11" FontSize="13" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#D0D7E0" VerticalAlignment="Center"/>
                                <TextBlock Text="B" FontSize="8" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#828B96" VerticalAlignment="Center" Margin="2,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Total -->
                    <Border x:Name="HomeTotalBadge" Grid.Column="4" Padding="4,0" VerticalAlignment="Center"
                            BorderThickness="1" Background="#0D1117">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="HomeTotalBorderBrush" Color="#4488FF"/>
                        </Border.BorderBrush>
                        <TextBlock x:Name="HomeTotalText" Text="107" FontSize="22" FontWeight="Black" FontFamily="Bahnschrift"
                                   VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush x:Name="HomeTotalFg" Color="#FFFFFF"/>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect x:Name="HomeTotalGlow" Color="#4488FF" ShadowDepth="0" BlurRadius="6" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- CENTER -->
            <Border Grid.Column="1" Background="#161B22">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="QuarterText" Text="QT" Foreground="#F0C040"
                               FontSize="13" FontWeight="Black" FontFamily="Bahnschrift"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TimerText" Text="19:57" Foreground="#58A6FF"
                               FontSize="9" FontWeight="Bold" FontFamily="Bahnschrift"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- AWAY SECTION -->
            <Border Grid.Column="2" BorderThickness="1,0,0,0">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="AwayBgBrush" Color="#FF6644"/>
                </Border.BorderBrush>
                <Border.Background>
                    <SolidColorBrush x:Name="AwaySectionBg" Color="#18FF6644"/>
                </Border.Background>
                <Grid Margin="3,2,3,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total (left of away) -->
                    <Border x:Name="AwayTotalBadge" Grid.Column="0" Padding="4,0" VerticalAlignment="Center"
                            BorderThickness="1" Background="#0D1117">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="AwayTotalBorderBrush" Color="#FF6644"/>
                        </Border.BorderBrush>
                        <TextBlock x:Name="AwayTotalText" Text="97" FontSize="22" FontWeight="Black" FontFamily="Bahnschrift"
                                   VerticalAlignment="Center">
                            <TextBlock.Foreground>
                                <SolidColorBrush x:Name="AwayTotalFg" Color="#FFFFFF"/>
                            </TextBlock.Foreground>
                            <TextBlock.Effect>
                                <DropShadowEffect x:Name="AwayTotalGlow" Color="#FF6644" ShadowDepth="0" BlurRadius="6" Opacity="0.7"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </Border>

                    <!-- G/B chips -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0,0,0">
                        <Border CornerRadius="3" Padding="3,0" BorderThickness="1" Margin="0,0,2,0" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="AwayGoalsChipBg" Color="#30FFFFFF"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="AwayGoalsChipBorder" Color="#FF6644"/>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect x:Name="AwayGoalsChipGlow" Color="#FF6644" ShadowDepth="0" BlurRadius="3" Opacity="0.5"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="AwayGoalsText" Text="14" FontSize="13" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="G" FontSize="8" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#B0B8C4" VerticalAlignment="Center" Margin="2,2,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="3" Padding="3,0" BorderThickness="1" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush x:Name="AwayBehindsChipBg" Color="#14FFFFFF"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush x:Name="AwayBehindsChipBorder" Color="#FF6644"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="AwayBehindsText" Text="9" FontSize="13" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#D0D7E0" VerticalAlignment="Center"/>
                                <TextBlock Text="B" FontSize="8" FontWeight="Black" FontFamily="Bahnschrift"
                                           Foreground="#828B96" VerticalAlignment="Center" Margin="2,2,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Abbreviation (right side) -->
                    <TextBlock Grid.Column="3" x:Name="AwayAbbrText" Text="GEEL"
                               FontSize="16" FontWeight="Black" FontFamily="Bahnschrift"
                               VerticalAlignment="Center" Margin="0,0,4,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush x:Name="AwayAbbrBrush" Color="#FF6644"/>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect x:Name="AwayAbbrGlow" Color="#FF6644" ShadowDepth="0" BlurRadius="4" Opacity="0.6"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Logo -->
                    <Grid Grid.Column="4" VerticalAlignment="Center">
                        <Ellipse x:Name="AwayLogoFallback" Width="22" Height="22" Fill="#22FFFFFF"/>
                        <Image x:Name="AwayLogoImage" Width="22" Height="22" Stretch="UniformToFill" Visibility="Collapsed">
                            <Image.Clip>
                                <EllipseGeometry Center="11,11" RadiusX="11" RadiusY="11"/>
                            </Image.Clip>
                        </Image>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 1px bottom border -->
        <Border Height="1" VerticalAlignment="Bottom" Background="#30363D" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
