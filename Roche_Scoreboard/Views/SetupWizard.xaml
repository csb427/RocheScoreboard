<UserControl x:Class="Roche_Scoreboard.Views.SetupWizard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#0D1117">

    <UserControl.Resources>
        <!-- ── Colour palette — broadcast control console ── -->
        <Color x:Key="Shell">#0D1117</Color>
        <Color x:Key="Surface0">#161B22</Color>
        <Color x:Key="Surface1">#1C2128</Color>
        <Color x:Key="Surface2">#21262D</Color>
        <Color x:Key="Surface3">#30363D</Color>
        <Color x:Key="Edge">#30363D</Color>
        <Color x:Key="EdgeHi">#484F58</Color>
        <Color x:Key="Accent">#58A6FF</Color>
        <Color x:Key="AccentDim">#1F6FEB</Color>
        <Color x:Key="TextBright">#E6EDF3</Color>
        <Color x:Key="TextMid">#8B949E</Color>
        <Color x:Key="TextDim">#484F58</Color>
        <Color x:Key="Go">#3FB950</Color>

        <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource Shell}"/>
        <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
        <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3}"/>
        <SolidColorBrush x:Key="EdgeBrush" Color="{StaticResource Edge}"/>
        <SolidColorBrush x:Key="EdgeHiBrush" Color="{StaticResource EdgeHi}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}"/>
        <SolidColorBrush x:Key="TextBrightBrush" Color="{StaticResource TextBright}"/>
        <SolidColorBrush x:Key="TextMidBrush" Color="{StaticResource TextMid}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>
        <SolidColorBrush x:Key="GoBrush" Color="{StaticResource Go}"/>

        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextBright}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextMid}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextDim}"/>

        <!-- ── Section heading — uppercase, tracked, strong ── -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMidBrush}"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- ── Field label — compact, dim ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ── Text field — inset, dark, high contrast caret ── -->
        <Style x:Key="WizardField" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ── Compact tool button — tactile press ── -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="12,5" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="BdSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface3Brush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource EdgeHiBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface0Brush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdSc" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BdSc" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary navigation button — bold, glowing accent ── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="160"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5" Padding="28,0"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale" Storyboard.TargetProperty="ScaleX" From="0.96" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BdScale" Storyboard.TargetProperty="ScaleY" From="0.96" To="1" Duration="0:0:0.12">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Step progress dot — round indicator ── -->
        <Style x:Key="StepDot" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════ -->
        <!-- LEFT: MAIN WIZARD CONTENT — full-screen steps -->
        <!-- ══════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Margin="32,20,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ── Header — brand + step context ── -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="ROCHE SCOREBOARD" Foreground="{StaticResource AccentBrush}" FontSize="10" FontWeight="Black" Margin="0,0,0,3"/>
                    <TextBlock Text="Match Setup" Foreground="White" FontSize="26" FontWeight="Black"/>
                    <TextBlock x:Name="StepSubtitle" Text="Select your teams" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ── Step progress bar — clickable, strong indicators ── -->
            <Grid Grid.Row="1" HorizontalAlignment="Left" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonUp="GoToStep1_Click">
                    <Border x:Name="Step1Dot" Style="{StaticResource StepDot}" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}">
                        <TextBlock Text="1" Foreground="White" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step1Label" Text="Teams" Foreground="White" FontWeight="Black" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="1" Width="32" Height="2" Background="{StaticResource EdgeBrush}" VerticalAlignment="Center" Margin="8,0"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonUp="GoToStep2_Click">
                    <Border x:Name="Step2Dot" Style="{StaticResource StepDot}">
                        <TextBlock Text="2" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step2Label" Text="Details" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="3" Width="32" Height="2" Background="{StaticResource EdgeBrush}" VerticalAlignment="Center" Margin="8,0"/>

                <StackPanel Grid.Column="4" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonUp="GoToStep3_Click">
                    <Border x:Name="Step3Dot" Style="{StaticResource StepDot}">
                        <TextBlock Text="3" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step3Label" Text="Clock" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>

                <Border Grid.Column="5" Width="32" Height="2" Background="{StaticResource EdgeBrush}" VerticalAlignment="Center" Margin="8,0"/>

                <StackPanel Grid.Column="6" Orientation="Horizontal" Cursor="Hand" MouseLeftButtonUp="GoToStep4_Click">
                    <Border x:Name="Step4Dot" Style="{StaticResource StepDot}">
                        <TextBlock Text="4" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step4Label" Text="Messages" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- ══════════════════════════════════════ -->
            <!-- STEP PANELS — each takes full space    -->
            <!-- ══════════════════════════════════════ -->
            <Grid Grid.Row="2">

                <!-- ═══ STEP 1: TEAM PRESETS — dominant card grid ═══ -->
                <Grid x:Name="Step1Panel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Visibility="Collapsed"/>

                    <!-- HOME preset zone -->
                    <Border Grid.Row="1" Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1,2,1,1" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="#1A3A6A" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Text="HOME TEAM" Foreground="#7EB4FF" FontSize="10" FontWeight="Black"/>
                                </Border>
                                <TextBlock x:Name="HomePresetEmpty" Text="No saved presets — set up manually on the next step" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <WrapPanel x:Name="HomePresetPanel"/>
                            </ScrollViewer>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save Current" Height="26" Margin="0,0,6,0" Click="SaveHomePreset_Click" Style="{StaticResource SmallBtn}" ToolTip="Save current team as preset"/>
                                <Button Content="Delete" Height="26" Click="DeleteHomePreset_Click" Style="{StaticResource SmallBtn}" ToolTip="Delete selected preset"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- AWAY preset zone -->
                    <Border Grid.Row="3" Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1,2,1,1" Padding="14,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Border Background="#4A1A1A" Padding="8,3" Margin="0,0,8,0">
                                    <TextBlock Text="AWAY TEAM" Foreground="#FF9A9A" FontSize="10" FontWeight="Black"/>
                                </Border>
                                <TextBlock x:Name="AwayPresetEmpty" Text="No saved presets — set up manually on the next step" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Visibility="Collapsed"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <WrapPanel x:Name="AwayPresetPanel"/>
                            </ScrollViewer>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Save Current" Height="26" Margin="0,0,6,0" Click="SaveAwayPreset_Click" Style="{StaticResource SmallBtn}" ToolTip="Save current team as preset"/>
                                <Button Content="Delete" Height="26" Click="DeleteAwayPreset_Click" Style="{StaticResource SmallBtn}" ToolTip="Delete selected preset"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ═══ STEP 2: TEAM DETAILS — asymmetric side-by-side ═══ -->
                <Grid x:Name="Step2Panel" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- HOME detail card — thicker top border in team accent -->
                    <Border Grid.Column="0" Background="{StaticResource Surface0Brush}" BorderBrush="#2A4A7A" BorderThickness="1,3,1,1" Padding="16,14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="HOME TEAM" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Team Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SetupHomeNameBox" Text="" Style="{StaticResource WizardField}" Margin="0,0,0,10" ToolTip="Full team name"/>

                                <TextBlock Text="Abbreviation (3-4 letters)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SetupHomeAbbrBox" Text="" Style="{StaticResource WizardField}" MaxLength="4" Margin="0,0,0,12" ToolTip="3-4 letter abbreviation"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Primary Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="SetupHomeColorBox" Width="80" Text="#0A2A6A" FontSize="11" FontFamily="Consolas" Background="{StaticResource Surface1Brush}" Foreground="{StaticResource TextBrightBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="6,4" CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Background colour" TextChanged="SetupHomeColorBox_TextChanged"/>
                                            <Border x:Name="SetupHomeColorPreview" Width="28" Height="26" Background="#0A2A6A" BorderBrush="{StaticResource EdgeHiBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickSetupHomeColor_Click" Margin="4,0,0,0" ToolTip="Colour picker"/>
                                            <Border Width="26" Height="26" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperSetupHomeColor_Click" Margin="3,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Text Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="SetupHomeSecondaryBox" Width="80" Text="#FFFFFF" FontSize="11" FontFamily="Consolas" Background="{StaticResource Surface1Brush}" Foreground="{StaticResource TextBrightBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="6,4" CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Text colour" TextChanged="SetupHomeSecondaryBox_TextChanged"/>
                                            <Border x:Name="SetupHomeSecondaryPreview" Width="28" Height="26" Background="#FFFFFF" BorderBrush="{StaticResource EdgeHiBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickSetupHomeSecondary_Click" Margin="4,0,0,0" ToolTip="Colour picker"/>
                                            <Border Width="26" Height="26" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperSetupHomeSecondary_Click" Margin="3,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,2,0,12"/>

                                <TextBlock Text="Logo" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Choose Logo" Height="28" Click="ChooseSetupHomeLogo_Click" Style="{StaticResource SmallBtn}" ToolTip="Select a team logo image"/>
                                    <TextBlock Grid.Column="1" x:Name="SetupHomeLogoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Border x:Name="SetupHomeLogoPreview" Background="{StaticResource Surface1Brush}" Padding="8" Margin="0,4,0,0" Visibility="Collapsed" HorizontalAlignment="Left">
                                    <Image x:Name="SetupHomeLogoImage" MaxHeight="60" MaxWidth="160" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,12,0,12"/>

                                <TextBlock Text="Goal Video (optional)" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Choose MP4" Height="28" Click="ChooseSetupHomeVideo_Click" Style="{StaticResource SmallBtn}" ToolTip="Select an MP4 goal animation video"/>
                                    <TextBlock Grid.Column="1" x:Name="SetupHomeVideoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- AWAY detail card — thicker top border in team accent -->
                    <Border Grid.Column="2" Background="{StaticResource Surface0Brush}" BorderBrush="#7A2A2A" BorderThickness="1,3,1,1" Padding="16,14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="AWAY TEAM" Style="{StaticResource SectionHead}"/>

                                <TextBlock Text="Team Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SetupAwayNameBox" Text="" Style="{StaticResource WizardField}" Margin="0,0,0,10" ToolTip="Full team name"/>

                                <TextBlock Text="Abbreviation (3-4 letters)" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SetupAwayAbbrBox" Text="" Style="{StaticResource WizardField}" MaxLength="4" Margin="0,0,0,12" ToolTip="3-4 letter abbreviation"/>

                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Primary Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="SetupAwayColorBox" Width="80" Text="#7A1A1A" FontSize="11" FontFamily="Consolas" Background="{StaticResource Surface1Brush}" Foreground="{StaticResource TextBrightBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="6,4" CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Background colour" TextChanged="SetupAwayColorBox_TextChanged"/>
                                            <Border x:Name="SetupAwayColorPreview" Width="28" Height="26" Background="#7A1A1A" BorderBrush="{StaticResource EdgeHiBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickSetupAwayColor_Click" Margin="4,0,0,0" ToolTip="Colour picker"/>
                                            <Border Width="26" Height="26" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperSetupAwayColor_Click" Margin="3,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Text Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="SetupAwaySecondaryBox" Width="80" Text="#FFFFFF" FontSize="11" FontFamily="Consolas" Background="{StaticResource Surface1Brush}" Foreground="{StaticResource TextBrightBrush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="6,4" CaretBrush="White" VerticalContentAlignment="Center" ToolTip="Text colour" TextChanged="SetupAwaySecondaryBox_TextChanged"/>
                                            <Border x:Name="SetupAwaySecondaryPreview" Width="28" Height="26" Background="#FFFFFF" BorderBrush="{StaticResource EdgeHiBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickSetupAwaySecondary_Click" Margin="4,0,0,0" ToolTip="Colour picker"/>
                                            <Border Width="26" Height="26" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperSetupAwaySecondary_Click" Margin="3,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,2,0,12"/>

                                <TextBlock Text="Logo" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Choose Logo" Height="28" Click="ChooseSetupAwayLogo_Click" Style="{StaticResource SmallBtn}" ToolTip="Select a team logo image"/>
                                    <TextBlock Grid.Column="1" x:Name="SetupAwayLogoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                                <Border x:Name="SetupAwayLogoPreview" Background="{StaticResource Surface1Brush}" Padding="8" Margin="0,4,0,0" Visibility="Collapsed" HorizontalAlignment="Left">
                                    <Image x:Name="SetupAwayLogoImage" MaxHeight="60" MaxWidth="160" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,12,0,12"/>

                                <TextBlock Text="Goal Video (optional)" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Content="Choose MP4" Height="28" Click="ChooseSetupAwayVideo_Click" Style="{StaticResource SmallBtn}" ToolTip="Select an MP4 goal animation video"/>
                                    <TextBlock Grid.Column="1" x:Name="SetupAwayVideoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="10" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- ═══ STEP 3: CLOCK — centred, prominent, amber accent ═══ -->
                <Border x:Name="Step3Panel" Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="24,20" Visibility="Collapsed">
                    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                        <TextBlock Text="CLOCK MODE" Style="{StaticResource SectionHead}"/>
                        <TextBlock Text="Choose how the game clock behaves during each quarter." Foreground="{StaticResource TextMidBrush}" FontSize="13" Margin="0,0,0,22" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                            <RadioButton x:Name="SetupCountUp" Content="Count Up" Foreground="White" FontSize="15" FontWeight="Black" IsChecked="True" GroupName="SetupClock" Margin="0,0,32,0" ToolTip="Clock counts upward from 00:00"/>
                            <RadioButton x:Name="SetupCountdown" Content="Countdown" Foreground="White" FontSize="15" FontWeight="Black" GroupName="SetupClock" Checked="SetupClockMode_Changed" Unchecked="SetupClockMode_Changed" ToolTip="Clock counts down from quarter length"/>
                        </StackPanel>

                        <Border x:Name="SetupDurationPanel" Background="{StaticResource Surface1Brush}" BorderBrush="#6B5A00" BorderThickness="1,2,1,1" Padding="18,14" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="QUARTER LENGTH" Foreground="#D29922" FontSize="10" FontWeight="Black" Margin="0,0,0,10"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="SetupQuarterMinutes" Width="64" FontSize="24" FontFamily="Consolas" Text="20" Background="{StaticResource Surface0Brush}" Foreground="#D29922" BorderBrush="#6B5A00" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CaretBrush="#D29922" ToolTip="Minutes"/>
                                    <TextBlock Text=":" Foreground="#6B5A00" FontSize="24" FontFamily="Consolas" VerticalAlignment="Center" Margin="6,0"/>
                                    <TextBox x:Name="SetupQuarterSeconds" Width="64" FontSize="24" FontFamily="Consolas" Text="00" Background="{StaticResource Surface0Brush}" Foreground="#D29922" BorderBrush="#6B5A00" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" CaretBrush="#D29922" ToolTip="Seconds"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ═══ STEP 4: MESSAGES — clean list ═══ -->
                <Border x:Name="Step4Panel" Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="24,20" Visibility="Collapsed">
                    <Grid MaxWidth="600" HorizontalAlignment="Left">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*" MinHeight="120"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="SCROLLING MESSAGES" Style="{StaticResource SectionHead}"/>
                        <TextBlock Grid.Row="1" Text="These scroll across the bottom bar during the game. Add venue name, sponsor messages, or match details." Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <Border Grid.Row="2" Background="{StaticResource Surface1Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Padding="8">
                            <ListBox x:Name="SetupMessageList" Background="Transparent" Foreground="White" FontSize="12" BorderThickness="0" MinHeight="100" ToolTip="Select and remove messages"/>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SetupNewMessageBox" Style="{StaticResource WizardField}" Margin="0,0,6,0" ToolTip="Type a message"/>
                            <Button Grid.Column="1" Content="Add" Height="30" Margin="0,0,4,0" Click="SetupAddMessage_Click" Style="{StaticResource SmallBtn}"/>
                            <Button Grid.Column="2" Content="Remove" Height="30" Click="SetupRemoveMessage_Click" Style="{StaticResource SmallBtn}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <!-- ── Navigation — strong, separated ── -->
            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0" Content="← Back" Click="Back_Click" Visibility="Collapsed"
                        Style="{StaticResource NavBtn}" Background="{StaticResource Surface2Brush}" BorderBrush="{StaticResource EdgeBrush}"/>

                <Button x:Name="NextButton" Grid.Column="2" Content="Next →" Click="Next_Click"
                        Style="{StaticResource NavBtn}" Background="{StaticResource AccentDimBrush}" BorderBrush="{StaticResource AccentBrush}"/>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════ -->
        <!-- RIGHT: LIVE PREVIEW SIDEBAR — always visible   -->
        <!-- ══════════════════════════════════════════════ -->
        <Border Grid.Column="1" Background="{StaticResource Surface0Brush}" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="2,0,0,0" Padding="16,20,16,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="LIVE PREVIEW" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Black" Margin="0,0,0,10"/>

                <!-- Mini scoreboard preview — dynamic team colours -->
                <Border Grid.Row="1" x:Name="PreviewContainer" Background="#0D1117" BorderBrush="{StaticResource EdgeBrush}" BorderThickness="1" Height="150" ClipToBounds="True" Margin="0,0,0,16">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="PreviewHomeBg" Background="#0A2A6A" Padding="10,8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="PreviewHomeAbbr" Text="HOM" Foreground="White" FontSize="18" FontWeight="Black" FontFamily="Bahnschrift" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PreviewHomeName" Text="Home Team" Foreground="#FFFFFFBB" FontSize="9" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Background="#0D1117" Padding="14,8">
                                <TextBlock Text="0 – 0" Foreground="White" FontSize="20" FontWeight="Black" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </Border>

                            <Border Grid.Column="2" x:Name="PreviewAwayBg" Background="#7A1A1A" Padding="10,8">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock x:Name="PreviewAwayAbbr" Text="AWA" Foreground="White" FontSize="18" FontWeight="Black" FontFamily="Bahnschrift" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="PreviewAwayName" Text="Away Team" Foreground="#FFFFFFBB" FontSize="9" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border Grid.Row="1" Background="#161B22" Padding="6,4" Margin="0,6,0,0">
                            <TextBlock Text="Q1  00:00" Foreground="{StaticResource TextDimBrush}" FontSize="11" FontFamily="Consolas" HorizontalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Summary info — structured readout -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="MATCH SUMMARY" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Black" Margin="0,0,0,8"/>

                    <Border Background="{StaticResource Surface1Brush}" Padding="10,8" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Home" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="PreviewHomeDetail" Text="—" Foreground="{StaticResource TextBrightBrush}" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource Surface1Brush}" Padding="10,8" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Away" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="PreviewAwayDetail" Text="—" Foreground="{StaticResource TextBrightBrush}" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource Surface1Brush}" Padding="10,8" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Clock" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="PreviewClockDetail" Text="Count Up" Foreground="{StaticResource TextBrightBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource Surface1Brush}" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Messages" Foreground="{StaticResource TextDimBrush}" FontSize="9" FontWeight="Bold"/>
                            <TextBlock x:Name="PreviewMessageCount" Text="0 messages" Foreground="{StaticResource TextBrightBrush}" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
