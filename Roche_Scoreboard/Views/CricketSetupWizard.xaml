<UserControl x:Class="Roche_Scoreboard.Views.CricketSetupWizard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#080C12">

    <UserControl.Resources>
        <!-- ═══════════════════════════════════ -->
        <!-- COLOUR SYSTEM — cinematic broadcast -->
        <!-- ═══════════════════════════════════ -->
        <Color x:Key="Shell">#080C12</Color>
        <Color x:Key="Surface0">#0E1420</Color>
        <Color x:Key="Surface1">#141C2A</Color>
        <Color x:Key="Surface2">#1A2436</Color>
        <Color x:Key="Surface3">#243044</Color>
        <Color x:Key="Edge">#2A3A52</Color>
        <Color x:Key="EdgeHi">#3A5070</Color>
        <Color x:Key="Accent">#818CF8</Color>
        <Color x:Key="AccentDim">#5B63C7</Color>
        <Color x:Key="TextBright">#E6EDF3</Color>
        <Color x:Key="TextMid">#8B949E</Color>
        <Color x:Key="TextDim">#484F58</Color>
        <Color x:Key="Go">#3FB950</Color>

        <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource Shell}"/>
        <SolidColorBrush x:Key="Surface0Brush" Color="{StaticResource Surface0}"/>
        <SolidColorBrush x:Key="Surface1Brush" Color="{StaticResource Surface1}"/>
        <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2}"/>
        <SolidColorBrush x:Key="Surface3Brush" Color="{StaticResource Surface3}"/>
        <SolidColorBrush x:Key="EdgeBrush" Color="{StaticResource Edge}"/>
        <SolidColorBrush x:Key="EdgeHiBrush" Color="{StaticResource EdgeHi}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}"/>
        <SolidColorBrush x:Key="TextBrightBrush" Color="{StaticResource TextBright}"/>
        <SolidColorBrush x:Key="TextMidBrush" Color="{StaticResource TextMid}"/>
        <SolidColorBrush x:Key="TextDimBrush" Color="{StaticResource TextDim}"/>
        <SolidColorBrush x:Key="GoBrush" Color="{StaticResource Go}"/>

        <!-- Legacy keys for compatibility -->
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextBright}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextMid}"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextDim}"/>

        <!-- ── Field label ── -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#6688AA"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- ── Text field — deep inset ── -->
        <Style x:Key="WizardField" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background">
                <Setter.Value><SolidColorBrush Color="#0A1018"/></Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="BorderBrush" Value="#1E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- ── Section heading — uppercase, tracked ── -->
        <Style x:Key="SectionHead" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- ── Card — region panel with subtle border ── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface1Brush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource EdgeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16"/>
        </Style>

        <!-- ── Compact tool button with click bounce ── -->
        <Style x:Key="SmallBtn" TargetType="Button">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Padding="12,5" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="BdSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E2C40"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A5070"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0A1018"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdSc" Storyboard.TargetProperty="ScaleX" From="0.95" To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="BdSc" Storyboard.TargetProperty="ScaleY" From="0.95" To="1" Duration="0:0:0.1">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ComboBox ── -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#243044"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A2436"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="28"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Border" Grid.ColumnSpan="2" Background="#0A1018" BorderBrush="#1E3050" BorderThickness="1"/>
                            <ContentPresenter Grid.Column="0" Margin="10,7" IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="#141C2A" BorderBrush="#1E3050" BorderThickness="1,0,0,0" Cursor="Hand">
                                            <Path Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource TextMidBrush}" StrokeThickness="1.5"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <Border Background="#0E1420" BorderBrush="#3A5070" BorderThickness="1"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#3A5070"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark ListBox ── -->
        <Style x:Key="DarkList" TargetType="ListBox">
            <Setter Property="Background" Value="#0A1018"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="BorderBrush" Value="#1E3050"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A2436"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#141C2A"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Navigation button with hover lift + click bounce ── -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0"
                                Padding="24,0" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><ScaleTransform x:Name="NavSc" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleX" To="1.03" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleY" To="1.03" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.Click">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleX" From="0.95" To="1.03" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="NavSc" Storyboard.TargetProperty="ScaleY" From="0.95" To="1.03" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><BackEase Amplitude="0.3" EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Dark RadioButton ── -->
        <Style x:Key="DarkRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource TextBrightBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Padding="14,8" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse x:Name="Dot" Width="14" Height="14" Stroke="#3A5070" StrokeThickness="1.5" Fill="Transparent" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Dot" Property="Fill" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Dot" Property="Stroke" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentDimBrush}"/>
                                <Setter TargetName="Bd" Property="Background" Value="#141828"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2436"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- BACKGROUND — cinematic atmosphere                      -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Opacity="0.02" IsHitTestVisible="False">
            <Border.Background>
                <VisualBrush TileMode="Tile" Viewport="0,0,40,40" ViewportUnits="Absolute"
                             Viewbox="0,0,40,40" ViewboxUnits="Absolute">
                    <VisualBrush.Visual>
                        <Canvas Width="40" Height="40">
                            <Line X1="0" Y1="40" X2="40" Y2="0" Stroke="White" StrokeThickness="1"/>
                        </Canvas>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.Background>
        </Border>

        <!-- Top-edge glow -->
        <Border Height="1" VerticalAlignment="Top" IsHitTestVisible="False" Opacity="0.3">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00000000" Offset="0"/>
                    <GradientStop Color="{StaticResource Accent}" Offset="0.5"/>
                    <GradientStop Color="#00000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid MaxWidth="980" Margin="32,16,32,24" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,14">
                <TextBlock Text="ROCHE SCOREBOARD — CRICKET" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Black" Margin="0,0,0,4"/>
                <TextBlock Text="Match Setup" Foreground="{StaticResource TextBrightBrush}" FontSize="26" FontWeight="Black"/>
                <TextBlock x:Name="StepSubtitle" Text="Configure both teams" Foreground="{StaticResource TextDimBrush}" FontSize="12" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Step indicator — broadcast-style horizontal stepper -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                <Border x:Name="Step1Dot" Width="32" Height="32" CornerRadius="16" Background="{StaticResource AccentBrush}">
                    <TextBlock Text="1" Foreground="White" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step1Label" Text="Teams" Foreground="{StaticResource TextBrightBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <Border x:Name="Step1Line" Width="36" Height="2" VerticalAlignment="Center" Margin="8,0" Background="{StaticResource EdgeBrush}"/>
                <Border x:Name="Step2Dot" Width="32" Height="32" CornerRadius="16" Background="{StaticResource Surface2Brush}">
                    <TextBlock Text="2" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step2Label" Text="Players" Foreground="{StaticResource TextDimBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
                <TextBlock x:Name="Step2Count" Text="" Foreground="{StaticResource TextMidBrush}" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                <Border x:Name="Step2Line" Width="36" Height="2" VerticalAlignment="Center" Margin="8,0" Background="{StaticResource EdgeBrush}"/>
                <Border x:Name="Step3Dot" Width="32" Height="32" CornerRadius="16" Background="{StaticResource Surface2Brush}">
                    <TextBlock Text="3" Foreground="{StaticResource TextDimBrush}" FontWeight="Black" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="Step3Label" Text="Match" Foreground="{StaticResource TextDimBrush}" FontWeight="Bold" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </StackPanel>

            <!-- Step content — animated container -->
            <Grid Grid.Row="2" x:Name="StepContainer" ClipToBounds="True">
                <!-- STEP 1: TEAMS -->
                <Grid x:Name="Step1Panel">
                    <Grid.RenderTransform><TranslateTransform x:Name="Step1Translate" X="0"/></Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Team A -->
                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="TEAM A (HOME)" Style="{StaticResource SectionHead}"/>
                                <!-- Preset -->
                                <TextBlock Text="Load Preset" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="TeamAPresetCombo" Style="{StaticResource DarkCombo}"/>
                                    <Button Grid.Column="1" Content="Load" Click="LoadPresetA_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                    <Button Grid.Column="2" Content="Save" Click="SavePresetA_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                </Grid>
                                <TextBlock Text="Team Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TeamANameBox" Style="{StaticResource WizardField}" Margin="0,0,0,8"/>
                                <TextBlock Text="Abbreviation" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TeamAAbbrBox" Style="{StaticResource WizardField}" MaxLength="4" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Primary Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TeamAColorBox" Width="72" Text="#CC0000" Style="{StaticResource WizardField}" Margin="0,0,3,0"/>
                                            <Border x:Name="TeamAColorPreview" Width="28" Height="28" Background="#CC0000" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickTeamAColor_Click"/>
                                            <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperTeamAColor_Click" Margin="2,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Text Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TeamASecondaryBox" Width="72" Text="#FFFFFF" Style="{StaticResource WizardField}" Margin="0,0,3,0"/>
                                            <Border x:Name="TeamASecondaryPreview" Width="28" Height="28" Background="#FFFFFF" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickTeamASecondary_Click"/>
                                            <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperTeamASecondary_Click" Margin="2,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <!-- Logo -->
                                <TextBlock Text="Logo" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="Browse…" Click="BrowseLogoA_Click" Style="{StaticResource SmallBtn}"/>
                                    <Button Content="Clear" Click="ClearLogoA_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                    <TextBlock x:Name="TeamALogoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Border x:Name="TeamALogoPreview" Background="{StaticResource Surface2Brush}" Padding="8" Margin="0,8,0,0" Visibility="Collapsed" HorizontalAlignment="Left">
                                    <Image x:Name="TeamALogoImage" MaxHeight="60" MaxWidth="160" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,10,0,10"/>
                                <TextBlock Text="PREVIEW" Style="{StaticResource FieldLabel}"/>
                                <Border x:Name="TeamAPreviewBar" Padding="12,8" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="TeamAPreviewBg" Color="#CC0000"/>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TeamAPreviewAbbr" Text="TMA" FontSize="16" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="TeamAPreviewFg" Color="#FFFFFF"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock x:Name="TeamAPreviewName" Text="Team A" FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="TeamAPreviewNameFg" Color="#FFFFFF"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- Team B -->
                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="TEAM B (AWAY)" Style="{StaticResource SectionHead}"/>
                                <TextBlock Text="Load Preset" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="TeamBPresetCombo" Style="{StaticResource DarkCombo}"/>
                                    <Button Grid.Column="1" Content="Load" Click="LoadPresetB_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                    <Button Grid.Column="2" Content="Save" Click="SavePresetB_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                </Grid>
                                <TextBlock Text="Team Name" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TeamBNameBox" Style="{StaticResource WizardField}" Margin="0,0,0,8"/>
                                <TextBlock Text="Abbreviation" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="TeamBAbbrBox" Style="{StaticResource WizardField}" MaxLength="4" Margin="0,0,0,8"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Primary Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TeamBColorBox" Width="72" Text="#000080" Style="{StaticResource WizardField}" Margin="0,0,3,0"/>
                                            <Border x:Name="TeamBColorPreview" Width="28" Height="28" Background="#000080" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickTeamBColor_Click"/>
                                            <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperTeamBColor_Click" Margin="2,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Text Colour" Style="{StaticResource FieldLabel}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox x:Name="TeamBSecondaryBox" Width="72" Text="#FFFFFF" Style="{StaticResource WizardField}" Margin="0,0,3,0"/>
                                            <Border x:Name="TeamBSecondaryPreview" Width="28" Height="28" Background="#FFFFFF" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="PickTeamBSecondary_Click"/>
                                            <Border Width="28" Height="28" Background="#141C2A" BorderBrush="#2A3A52" BorderThickness="1" Cursor="Hand" MouseLeftButtonUp="DropperTeamBSecondary_Click" Margin="2,0,0,0" ToolTip="Eye dropper">
                                                <TextBlock Text="💧" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Logo" Style="{StaticResource FieldLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Button Content="Browse…" Click="BrowseLogoB_Click" Style="{StaticResource SmallBtn}"/>
                                    <Button Content="Clear" Click="ClearLogoB_Click" Style="{StaticResource SmallBtn}" Margin="4,0,0,0"/>
                                    <TextBlock x:Name="TeamBLogoText" Text="(none)" Foreground="{StaticResource TextDimBrush}" FontSize="11" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                                <Border x:Name="TeamBLogoPreview" Background="{StaticResource Surface2Brush}" Padding="8" Margin="0,8,0,0" Visibility="Collapsed" HorizontalAlignment="Left">
                                    <Image x:Name="TeamBLogoImage" MaxHeight="60" MaxWidth="160" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,10,0,10"/>
                                <TextBlock Text="PREVIEW" Style="{StaticResource FieldLabel}"/>
                                <Border x:Name="TeamBPreviewBar" Padding="12,8" Margin="0,4,0,0">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="TeamBPreviewBg" Color="#000080"/>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="TeamBPreviewAbbr" Text="TMB" FontSize="16" FontWeight="Black" FontFamily="Bahnschrift" VerticalAlignment="Center" Margin="0,0,12,0">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="TeamBPreviewFg" Color="#FFFFFF"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                        <TextBlock x:Name="TeamBPreviewName" Text="Team B" FontSize="14" FontWeight="Bold" VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush x:Name="TeamBPreviewNameFg" Color="#FFFFFF"/>
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- STEP 2: PLAYERS -->
                <Grid x:Name="Step2Panel" Visibility="Collapsed">
                    <Grid.RenderTransform><TranslateTransform x:Name="Step2Translate" X="0"/></Grid.RenderTransform>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TeamAPlayersLabel" Text="TEAM A PLAYERS" Style="{StaticResource SectionHead}"/>
                            <TextBlock Grid.Row="1" Text="Add as many players as needed" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,6"/>
                            <ListBox Grid.Row="2" x:Name="TeamAPlayerList" Style="{StaticResource DarkList}" MinHeight="120"/>
                            <Grid Grid.Row="3" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TeamAFirstNameBox" Style="{StaticResource WizardField}" Tag="First name" KeyDown="TeamAPlayerBox_KeyDown"/>
                                <TextBox Grid.Column="2" x:Name="TeamALastNameBox" Style="{StaticResource WizardField}" Tag="Last name" KeyDown="TeamAPlayerBox_KeyDown"/>
                                <Button Grid.Column="3" Content="+" Width="28" Height="28" Margin="4,0,0,0" Click="AddTeamAPlayer_Click" Style="{StaticResource SmallBtn}"/>
                                <Button Grid.Column="4" Content="−" Width="28" Height="28" Margin="3,0,0,0" Click="RemoveTeamAPlayer_Click" Style="{StaticResource SmallBtn}"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock x:Name="TeamBPlayersLabel" Text="TEAM B PLAYERS" Style="{StaticResource SectionHead}"/>
                            <TextBlock Grid.Row="1" Text="Add as many players as needed" Foreground="{StaticResource TextDimBrush}" FontSize="11" Margin="0,0,0,6"/>
                            <ListBox Grid.Row="2" x:Name="TeamBPlayerList" Style="{StaticResource DarkList}" MinHeight="120"/>
                            <Grid Grid.Row="3" Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TeamBFirstNameBox" Style="{StaticResource WizardField}" Tag="First name" KeyDown="TeamBPlayerBox_KeyDown"/>
                                <TextBox Grid.Column="2" x:Name="TeamBLastNameBox" Style="{StaticResource WizardField}" Tag="Last name" KeyDown="TeamBPlayerBox_KeyDown"/>
                                <Button Grid.Column="3" Content="+" Width="28" Height="28" Margin="4,0,0,0" Click="AddTeamBPlayer_Click" Style="{StaticResource SmallBtn}"/>
                                <Button Grid.Column="4" Content="−" Width="28" Height="28" Margin="3,0,0,0" Click="RemoveTeamBPlayer_Click" Style="{StaticResource SmallBtn}"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- STEP 3: MATCH SETTINGS -->
                <Border x:Name="Step3Panel" Style="{StaticResource Card}" Visibility="Collapsed">
                    <Border.RenderTransform><TranslateTransform x:Name="Step3Translate" X="0"/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                            <TextBlock Text="MATCH FORMAT" Style="{StaticResource SectionHead}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton x:Name="FormatLimited" Content="Limited Overs" Style="{StaticResource DarkRadio}" IsChecked="True" GroupName="CricketFormat" Checked="Format_Changed" Margin="0,0,10,0"/>
                                <RadioButton x:Name="FormatMultiDay" Content="Multi-Day (Unlimited)" Style="{StaticResource DarkRadio}" GroupName="CricketFormat" Checked="Format_Changed"/>
                            </StackPanel>
                            <StackPanel x:Name="OversPanel" Margin="0,0,0,14">
                                <TextBlock Text="Total Overs" Foreground="{StaticResource TextMidBrush}" FontSize="12" FontWeight="Bold" Margin="0,0,0,4"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="TotalOversBox" Width="60" Style="{StaticResource WizardField}" Text="50" HorizontalContentAlignment="Center"/>
                                    <TextBlock Text="overs per innings" Foreground="{StaticResource TextDimBrush}" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,0,0,14"/>

                            <TextBlock Text="TOSS" Style="{StaticResource SectionHead}"/>
                            <TextBlock Text="Who won the toss?" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="TossTeamA" Content="Team A" Style="{StaticResource DarkRadio}" IsChecked="True" GroupName="TossWinner" Margin="0,0,10,0"/>
                                <RadioButton x:Name="TossTeamB" Content="Team B" Style="{StaticResource DarkRadio}" GroupName="TossWinner"/>
                            </StackPanel>
                            <TextBlock Text="Elected to…" Foreground="{StaticResource TextMidBrush}" FontSize="12" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <RadioButton x:Name="TossElectedBat" Content="Bat" Style="{StaticResource DarkRadio}" IsChecked="True" GroupName="TossChoice" Margin="0,0,10,0"/>
                                <RadioButton x:Name="TossElectedBowl" Content="Bowl" Style="{StaticResource DarkRadio}" GroupName="TossChoice"/>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource EdgeBrush}" Margin="0,0,0,14"/>

                            <TextBlock Text="TICKER MESSAGES" Style="{StaticResource SectionHead}"/>
                            <ListBox x:Name="MessageList" Style="{StaticResource DarkList}" MinHeight="50"/>
                            <Grid Margin="0,6,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="NewMessageBox" Style="{StaticResource WizardField}" Margin="0,0,4,0"/>
                                <Button Grid.Column="1" Content="Add" Height="28" Margin="0,0,3,0" Click="AddMessage_Click" Style="{StaticResource SmallBtn}"/>
                                <Button Grid.Column="2" Content="Remove" Height="28" Click="RemoveMessage_Click" Style="{StaticResource SmallBtn}"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Navigation -->
            <Grid Grid.Row="3" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BackButton" Content="← Back" Click="Back_Click" Visibility="Collapsed" Style="{StaticResource NavBtn}">
                    <Button.Background><SolidColorBrush Color="{StaticResource Surface2}"/></Button.Background>
                </Button>
                <Button x:Name="NextButton" Grid.Column="2" Content="Next →" Click="Next_Click" Style="{StaticResource NavBtn}">
                    <Button.Background><SolidColorBrush Color="{StaticResource Accent}"/></Button.Background>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>